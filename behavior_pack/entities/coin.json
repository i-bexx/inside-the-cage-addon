{
  "format_version": "1.13.0",
  "minecraft:entity": {
    "description": {
      "identifier": "game:coin",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "default": {
        "minecraft:mark_variant": {
          "value": 0
        }
