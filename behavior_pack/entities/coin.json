      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": false
          }
        ]
      },
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": false
      },
      "minecraft:nameable": {},
      "minecraft:fire_immune": false,
      "minecraft:behavior.hurt_by_target": {
        "priority": 1
      },
      "minecraft:physics": {}
    },

   "events": {
    "minecraft:entity_spawned": {
      "add": {
        "component_groups": [
