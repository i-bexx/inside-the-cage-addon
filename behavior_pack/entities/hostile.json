{
  "format_version": "1.13.0",
  "minecraft:entity": {
    "description": {
      "identifier": "game:hostile",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false,

      "scripts": {
        "animate": [
          "hostile_controller"
        ]
      },
      "animations": {
        "hostile_controller": "controller.animation.hostile",
        "hostile_just_spawned": "animation.hostile_just_spawned",
        "hostile_can_move": "animation.hostile_can_move"
      }
    },
    "component_groups": {
      "can_move": {
        "minecraft:movement": {
          "value": 0.23
        },
        "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 6,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9,
        "probability": 0.2
      }
      },
      "hostile_dead": {
        "minecraft:instant_despawn": {
          "remove_child_entities": true
        }
      }
    },
		"components": {
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "on_damage": {
              "filters": {
                "all_of": [
                  {
                    "test": "is_family",
                    "subject": "other",
                    "value": "player"
                  },
                  {
                    "test": "is_family",
                    "subject": "self",
                    "value": "monster"
                  }
                ]
              },
              "event": "bad_luck",
              "target": "other"
            }
          }
        ]
      },
           
            "minecraft:collision_box": {
              "width": 0.6,
              "height": 1.9
            },
            "minecraft:health": {
              "value": 50,
              "max": 50
            },
            "minecraft:knockback_resistance": {
              "value": 100,
              "max": 100
            },
			"minecraft:type_family": {
				"family": [ "game", "monster", "mob" ]
			  },
			"minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": false
            },
            "minecraft:movement.basic": {
      },
      "minecraft:movement": {
          "value": 0
        },
      "minecraft:navigation.walk": {
        "is_amphibious": true,
        "can_pass_doors": true,
        "can_walk": true,
        "can_break_doors": true
      },
      "minecraft:jump.static": {
      },
      "minecraft:can_climb": {
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:behavior.melee_attack": {
        "priority": 3
      },
      "minecraft:behavior.random_stroll": {
        "priority": 7,
        "speed_multiplier": 1
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 6,
        "probability": 0.0
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9,
        "probability": 0.0
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 1
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 25.0,
        "must_see_forget_duration": 17.0,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "player" }
              ]
            },
            "max_dist": 35
          }
        ]
      },
      "minecraft:conditional_bandwidth_optimization": {
      },
			"minecraft:physics": {}
		},

   "events": {
    "minecraft:entity_spawned": {
      "trigger": "spawn_event"
    },
    "spawn_event": {
      "sequence": [
        {
          "queue_command": {
            "command": ["execute at @s run particle spawn:hostile ~ ~ ~", "execute at @s run playsound hostile_spawn @a[r=15] ~ ~ ~"]
          }
        }
      ]
    },
      "can_move_event": {
        "randomize": [
          {
            "weight": 100,
            "sequence": [
              {
                "add": {
          "component_groups": [
            "can_move"
          ]
        },
        "queue_command": {
          "command": [
          ]
        }
              }
            ]
          }
        ]
      },
      "hostile_dead_event": {
        "add": {
          "component_groups": [
            "hostile_dead"
          ]
        }
      }
      }
  }
}

