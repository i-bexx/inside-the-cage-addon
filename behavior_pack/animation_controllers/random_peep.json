{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.random_peep_BP": {
      "states": {
        "default": {
          "transitions": [ { "is_standing_up": "query.mark_variant == 1" } ]
        },
        "is_standing_up": {
          "animations": [ "is_standing_up" ],
          "transitions": [ { "is_healed": "query.all_animations_finished" } ]
        },
        "is_healed": {
          "on_entry": [ "@s is_healed_event" ],
          "transitions": [ { "default": "query.mark_variant == 0" } ]
        }
      }
    }
  }
}