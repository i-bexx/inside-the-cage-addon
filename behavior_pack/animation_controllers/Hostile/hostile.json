{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.hostile": {
      "states": {
        "default": {
          "animations": [
            "hostile_just_spawned"
          ],
          "transitions": [
            { "can_move": "query.all_animations_finished" },
            { "dead": "!(query.is_alive)" }
          ]
        },
        "can_move": {
          "animations": [
            "hostile_can_move"
          ],
          "transitions": [
            { "dead": "!(query.is_alive)" }
          ]
        },
        "dead": {
          "on_entry": [
            "@s hostile_dead_event",
            "/execute at @s run summon game:hostile_dead ~ ~ ~"
          ]
        }
      }
  }
  }
}


