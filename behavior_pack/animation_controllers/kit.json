{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.kit": {
      "states": {
        "default": {
          "transitions": [
            { "kit_use": "query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit') && query.is_using_item" }
          ]
        },
        "kit_use": {
          "animations": [
            "kit_use"
          ],
          "transitions": [
            { "default": "(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit') && !(query.is_using_item)) || !(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit')) " }
          ]
        }
      }
  }
  }
}


