{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.random_peep": {
        "states": {
          "default": {
            "animations": [ "is_sick_idle" ],
            "transitions": [
              {
                "is_healed": "query.mark_variant == 1"
              }
            ]
          },
          "is_healed": {
            "animations": [ "is_healed_idle" ],
            "transitions": [
              {
                "default": "query.mark_variant == 0"
              }
            ]
          }
        }
      }
    }
  }