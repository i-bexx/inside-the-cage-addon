{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.coin": {
      "states": {
				"default": {
					"animations": [
							"spin_anim"
					],
					"transitions": [
						{ "collected": "query.mark_variant == 1" }
					],
					"blend_transition": 0.3
				},
				"collected": {
					"animations": [
							"collected_anim"
					],
					"blend_transition": 0.3
				}
      }
  }
  }
}
