{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.gun": {
      "states": {
          "default": {
            "animations": [
              "first_person_hold"
            ],
            "transitions": [
              { "third_person": "!(c.is_first_person)" }
            ]
          },
          "third_person": {
            "animations": [
              "third_person_hold"
            ],
            "transitions": [
              { "default": "c.is_first_person" }
            ],
            "blend_transition": 0.3
          }
      }
  }
  }
}


