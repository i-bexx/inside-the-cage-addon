{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.gun_chamber": {
      "states": {
          "default": {
            "transitions": [
              { "chamber": "query.is_item_name_any('slot.weapon.mainhand', 0, 'game:gun') && query.variant == 3" }
            ]
          },
          "chamber": {
            "animations": [
              "chamber_anim"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:gun')) && (query.variant != 3 || query.all_animations_finished)" }
            ],
            "blend_transition": 0.3
          }
      }
  }
  }
}


