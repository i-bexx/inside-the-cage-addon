{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.hostile": {
      "states": {
          "default": {
            "animations": [
              "spawn"
            ],
            "transitions": [
              { "idle": "query.all_animations_finished && !(query.is_moving) && variable.attack_time <= 0" },
              { "move": "query.all_animations_finished && query.is_moving && variable.attack_time <= 0" },
              { "attack": "query.all_animations_finished && variable.attack_time > 0" }
            ],
              "blend_transition": 0.3
          },
          "idle": {
            "animations": [
              "idle"
            ],
            "transitions": [
              { "move": "query.all_animations_finished && query.is_moving && variable.attack_time <= 0" },
              { "attack": "query.all_animations_finished && variable.attack_time > 0" }
            ],
            "blend_transition": 0.3
          },
          "move": {
            "animations": [
              "move"
            ],
            "transitions": [
              { "idle": "query.all_animations_finished && !(query.is_moving) && variable.attack_time <= 0" },
              { "attack": "query.all_animations_finished && variable.attack_time > 0" }
            ],
            "blend_transition": 0.3
          },
          "attack": {
            "animations": [
              "attack"
            ],
            "transitions": [
              { "idle": "query.all_animations_finished && !(query.is_moving) && variable.attack_time <= 0" },
              { "move": "query.all_animations_finished && query.is_moving && variable.attack_time <= 0" }
            ],
            "blend_transition": 0.3
          }
      }
  }
  }
}
