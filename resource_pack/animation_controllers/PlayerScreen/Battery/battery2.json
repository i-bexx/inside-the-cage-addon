{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.battery2": {
      "states": {
          "default": {
            "transitions": [
              { "battery_increase2": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:increase2')" },
              { "battery_decrease2": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:decrease2')" }
            ]
        },
        "battery_increase2": {
          "animations": [
              "battery_increase2"
            ],
            "transitions": [
            { "battery_decrease2": "q.is_item_name_any('slot.armor.head', 'battery:decrease2')" },
            { "default": "query.mark_variant < 555"}
          ]
        },
        "battery_decrease2": {
          "animations": [
              "battery_decrease2"
              ],
              "transitions": [
                { "battery_increase2": "q.is_item_name_any('slot.armor.head', 'battery:increase2')" },
                { "default": "query.mark_variant < 555"}
              ],
              "blend_transition": 0.3
        } 
      }
  }
  }
}
