{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.battery1": {
      "states": {
          "default": {
            "transitions": [
              { "battery_increase1": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:increase1')" },
              { "battery_decrease1": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:decrease1')" }
            ]
        },
        "battery_increase1": {
          "animations": [
              "battery_increase1"
            ],
            "transitions": [
            { "battery_decrease1": "q.is_item_name_any('slot.armor.head', 'battery:decrease1')" },
            { "default": "query.mark_variant < 555"}
          ]
        },
        "battery_decrease1": {
          "animations": [
              "battery_decrease1"
              ],
              "transitions": [
                { "battery_increase1": "q.is_item_name_any('slot.armor.head', 'battery:increase1')" },
                { "default": "query.mark_variant < 555"}
              ],
              "blend_transition": 0.3
        } 
      }
  }
  }
}
