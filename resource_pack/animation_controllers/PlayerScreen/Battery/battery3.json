{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.battery3": {
      "states": {
          "default": {
            "transitions": [
              { "battery_increase3": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:increase3')" },
              { "battery_decrease3": "q.is_alive && q.is_item_name_any('slot.armor.head', 'battery:decrease3')" }
            ]
        },
        "battery_increase3": {
          "animations": [
              "battery_increase3"
            ],
            "transitions": [
            { "battery_decrease3": "q.is_item_name_any('slot.armor.head', 'battery:decrease3')" },
            { "default": "query.mark_variant < 555"}
          ]
        },
        "battery_decrease3": {
          "animations": [
              "battery_decrease3"
              ],
              "transitions": [
                { "battery_increase3": "q.is_item_name_any('slot.armor.head', 'battery:increase3')" },
                { "default": "query.mark_variant < 555"}
              ],
              "blend_transition": 0.3
        } 
      }
  }
  }
}
