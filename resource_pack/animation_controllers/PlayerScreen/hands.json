            "transitions": [
              { "holding_knife": "query.all_animations_finished && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:knife')" },
              { "attacking_knife": "(variable.attack_time > 0 && variable.item_use_normalized <= 0) && v.knife_attack_index <= 0.5 && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:knife')" },
              { "attacking_knife2": "(variable.attack_time > 0 && variable.item_use_normalized <= 0) && v.knife_attack_index > 0.5 && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:knife')" },
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:knife'))" }
            ]
          },
          "toxic_bomb_pick_up": {
            "animations": [
              "toxic_bomb_pick_up"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb'))" },
              { "toxic_bomb_hold": "query.all_animations_finished && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb') && !(q.is_using_item)"},
              { "toxic_bomb_use": "q.is_using_item && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb')" }
            ],
            "blend_transition": 0.3
          },
          "toxic_bomb_hold": {
            "animations": [
              "toxic_bomb_hold"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb'))" },
              { "toxic_bomb_use": "q.is_using_item && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb')" }
            ],
            "blend_transition": 0.3
          },
          "toxic_bomb_use": {
            "animations": [
              "toxic_bomb_use"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb'))" },
              { "toxic_bomb_hold": "!(q.is_using_item) && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:toxic_bomb') && query.all_animations_finished" }
            ],
            "blend_transition": 0.3
          },
          "kit_pick_up": {
            "animations": [
              "kit_pick_up"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit'))" },
              { "holding_kit": "query.all_animations_finished && query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit')" }
            ],
            "blend_transition": 0.3
          },
          "holding_kit": {
            "animations": [
              "holding_kit"
            ],
            "transitions": [
              { "default": "!(query.is_item_name_any('slot.weapon.mainhand', 0, 'game:kit'))" }
            ],
            "blend_transition": 0.3
          }
      }
  }
  }
}


