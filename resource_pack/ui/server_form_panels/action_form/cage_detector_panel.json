{
  "namespace": "cage_detector_panel",

  "cage_detector_panel_container": {
    "type": "panel",
    "size": [ "100%", "fill" ],
    "controls": [
      {
        "right_side": {
          "type": "collection_panel",
          "size": [ "100%cm", "100%" ],
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "collection_name": "form_buttons",
          "controls": [
            {
              "distance_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [ -5, 5 ],
                "collection_index": 0,
                "controls": [
                  {
                    "distance_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "font_type": "smooth",
                      "font_scale_factor": 1.2,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('Cage distance: ' + '§a' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "error_integer_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [ -5, -8 ],
                "collection_index": 1,
                "controls": [
                  {
                    "error_integer_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "font_type": "smooth",
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('Error integer: ' + '§6' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "left_side": {
          "type": "collection_panel",
          "size": [ "100%cm", "100%" ],
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "collection_name": "form_buttons",
          "controls": [
            {
              "signal_info_container": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [ "100%cm", 24 ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [ 5, 5 ],
                "collection_index": 2,
                "controls": [
                  {
                    "label_wrapper": {
                      "type": "panel",
                      "size": [ "100%c", "100%" ],
                      "controls": [
                        {
                          "signal_info_label": {
                            "type": "label",
                            "text": "Signal: ",
                            "size": [ "default", "default" ],
                            "anchor_from": "left_middle",
                            "anchor_to": "left_middle",
                            "color": [ 0.2, 0.8, 1.0 ],
                            "shadow": true
                          }
                        }
                      ]
                    }
                  },
                  {
                    "image_wrapper": {
                      "type": "panel",
                      "size": [ "100%c", "100%" ],
                      "controls": [
                        {
                          "signal_info_image": {
                            "type": "image",
                            "size": [ 48, 16 ],
                            "anchor_from": "top_middle",
                            "anchor_to": "top_middle",
                            "bindings": [
                              {
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons",
                                "binding_name": "#form_button_texture",
                                "binding_name_override": "#texture"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "idk2_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "center",
                "anchor_to": "center",
                "offset": [ 5, 0 ],
                "collection_index": 3,
                "controls": [
                  {
                    "idk2_label": {
                      "type": "label",
                      "text": "#form_button_text",
                      "size": [ "default", "default" ],
                      "color": [ 0.2, 0.8, 1.0 ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "idk3_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [ 5, -8 ],
                "collection_index": 4,
                "controls": [
                  {
                    "idk3_label": {
                      "type": "label",
                      "text": "#form_button_text",
                      "size": [ "default", "default" ],
                      "color": [ 0.2, 0.8, 1.0 ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}