            {
              "padding": {
                "type": "panel",
                "size": [ 0, 8 ]
              }
            },
            {
              "idk2_container": {
                "type": "collection_panel",
                "collection_index": 3,
                "size": [ "100%c", "100%c" ],
                "controls": [
                  {
                    "idk2_label": {
                      "type": "label",
                      "text": "#form_button_text",
                      "size": [ "default", "default" ],
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        }
                      ]
                    }
                  }
                ]
