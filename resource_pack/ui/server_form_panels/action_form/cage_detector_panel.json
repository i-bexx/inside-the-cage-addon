{
  "namespace": "cage_detector_panel",

  "cage_detector_panel_container": {
    "type": "panel",
    "size": [ "100%", "fill" ],
    "controls": [
      {
        "right_side": {
          "type": "collection_panel",
          "size": [ "100%cm", "100%" ],
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "collection_name": "form_buttons",
          "controls": [
            {
              "distance_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "offset": [ -5, 5 ],
                "collection_index": 0,
                "controls": [
                  {
                    "distance_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "font_type": "smooth",
                      "font_scale_factor": 1.2,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('Cage distance: ' + '§a' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "error_integer_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [ -5, -8 ],
                "collection_index": 1,
                "controls": [
                  {
                    "error_integer_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "font_type": "smooth",
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('Error integer: ' + '§6' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "left_side": {
          "type": "collection_panel",
          "size": [ "100%cm", "100%" ],
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "offset": [ 5, 0 ],
          "collection_name": "form_buttons",
          "controls": [
            {
              "signal_info_container": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [ "100%c", 24 ],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [ 0, 5 ],
                "collection_index": 2,
                "controls": [
                  {
                    "label_wrapper": {
                      "type": "panel",
                      "size": [ "100%c", "100%" ],
                      "controls": [
                        {
                          "signal_info_label": {
                            "type": "label",
                            "text": "§8Signal: ",
                            "size": [ "default", "default" ],
                            "anchor_from": "left_middle",
                            "anchor_to": "left_middle",
                            "color": [ 0.2, 0.8, 1.0 ],
                            "shadow": true
                          }
                        }
                      ]
                    }
                  },
                  {
                    "image_wrapper": {
                      "type": "panel",
                      "size": [ "100%c", "100%" ],
                      "controls": [
                        {
                          "signal_info_image": {
                            "type": "image",
                            "size": [ 48, 16 ],
                            "anchor_from": "top_middle",
                            "anchor_to": "top_middle",
                            "bindings": [
                              {
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons",
                                "binding_name": "#form_button_texture",
                                "binding_name_override": "#texture"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "elevation_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "collection_index": 3,
                "controls": [
                  {
                    "elevation_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('§8' + 'Elevation: ' + '§b' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            {
              "eta_container": {
                "type": "collection_panel",
                "size": [ "100%c", "100%c" ],
                "anchor_from": "bottom_left",
                "anchor_to": "bottom_left",
                "offset": [ 0, -8 ],
                "collection_index": 4,
                "controls": [
                  {
                    "eta_label": {
                      "type": "label",
                      "text": "#text",
                      "size": [ "default", "default" ],
                      "shadow": true,
                      "bindings": [
                        {
                          "binding_type": "collection",
                          "binding_collection_name": "form_buttons",
                          "binding_name": "#form_button_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('§8' + 'ETA: ' + '§e' + #form_button_text)",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "static_phase1_show": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.06,
    "from": 1,
    "to": 1,
    "next": "@cage_detector_panel.static_phase1_hide"
  },
  "static_phase1_hide": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.12,
    "from": 0,
    "to": 0,
    "next": "@cage_detector_panel.static_phase1_show"
  },

  "static_phase2_hide1": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.06,
    "from": 0,
    "to": 0,
    "next": "@cage_detector_panel.static_phase2_show"
  },
  "static_phase2_show": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.06,
    "from": 1,
    "to": 1,
    "next": "@cage_detector_panel.static_phase2_hide2"
  },
  "static_phase2_hide2": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.06,
    "from": 0,
    "to": 0,
    "next": "@cage_detector_panel.static_phase2_hide1"
  },

  "static_phase3_hide": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.12,
    "from": 0,
    "to": 0,
    "next": "@cage_detector_panel.static_phase3_show"
  },
  "static_phase3_show": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.06,
    "from": 1,
    "to": 1,
    "next": "@cage_detector_panel.static_phase3_hide"
  }
}