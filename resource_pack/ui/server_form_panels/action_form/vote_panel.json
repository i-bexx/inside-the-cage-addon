{
  "namespace": "vote_panel",

  "vote_panel_container" : {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      { "button_creator@vote_panel.button_creator": {} }
    ]
  },
  
  "button_creator": {
    "type": "grid",
    "size": [248, "100%c"],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",

    "$focus_wrap_enabled": true,

    "$default_button_texture": "textures/ui/panels/vote-question_panel/button_background_default",
    "$hover_button_texture": "textures/ui/panels/vote-question_panel/button_background_hover",
    "$pressed_button_texture": "textures/ui/panels/vote-question_panel/button_background_hover",
    "$hide_light_borders": true,

    "$hover_text_color": [ 0.0, 0.0, 0.0 ],

    "focus_container": true,
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_right": "stop",
    
    "grid_dimensions": [1, 3],
    "maximum_grid_items": 3,
    "grid_item_template": "action_form_panels.button_panel_small",
    "collection_name": "form_buttons"
  }
}