{
  "namespace": "shop_panel",

  "shop_panel_container": {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "scroll_view@server_form_main_templates.scroll_view": {
          "$scrolling_content": "shop_panel.button_creator"
        }
      }
    ]
  },
  
  "button_creator": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"], 
    
    "$button_control_path": "shop_panel.shop_panel_buttons",
    "$button_control_name": "shop_panel_buttons",
    "controls": [
      {
        "row_1_wrapper": {
          "type": "panel",
          "size": ["100%", 74], 
          "controls": [
            {
              "shop_button_container_1": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74], 
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "none",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "gun_button@action_form_panels.button_panel": {
                      "collection_index": 0,

                      "$default_text": "(%.3s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.4s * #form_button_text))",
                      "$focus_identifier": "gun_button_focus_id",
                      "$default_focus_precedence": 10
                    }
                  },
                  {
                    "knife_button@action_form_panels.button_panel": {
                      "collection_index": 1,

                      "$default_text": "(%.5s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.6s * #form_button_text))",
                      "$focus_identifier": "knife_button_focus_id",
                      "$default_focus_precedence": 9
                    }
                  },
                  {
                    "kit_button@action_form_panels.button_panel": {
                      "collection_index": 2,

                      "$default_text": "(%.3s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.4s * #form_button_text))",
                      "$focus_identifier": "kit_button_focus_id",
                      "$default_focus_precedence": 8
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_1": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_2_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_3"
                  }
                ],
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_1"
                  }
                ],
                "controls": [
                  {
                    "toxic_bomb_button@action_form_panels.button_panel": {
                      "collection_index": 3,

                      "$default_text": "(%.10s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.11s * #form_button_text))",
                      "$focus_identifier": "toxic_bomb_button_focus_id",
                      "$default_focus_precedence": 7
                    }
                  },
                  {
                    "ammo_button@action_form_panels.button_panel": {
                      "collection_index": 4,

                      "$default_text": "(%.4s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.5s * #form_button_text))",
                      "$focus_identifier": "ammo_button_focus_id",
                      "$default_focus_precedence": 6
                    }
                  },
                  {
                    "battery_button@action_form_panels.button_panel": {
                      "collection_index": 5,
                      
                      "$default_text": "(%.7s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.8s * #form_button_text))",
                      "$focus_identifier": "battery_button_focus_id",
                      "$default_focus_precedence": 5
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_2": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_3_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_3": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                
                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "stop",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "btn_6@action_form_panels.button_panel": {
                      "collection_index": 6,

                      "$default_text": "(%.8s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text - (%.9s * #form_button_text))",
                      "$focus_identifier": "null1_button_focus_id",
                      "$default_focus_precedence": 4
                    }
                  },
                  {
                    "btn_7@action_form_panels.button_panel": {
                      "collection_index": 7,

                      "$default_text": "(%.13s * #form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text)",
                      "$focus_identifier": "null2_button_focus_id",
                      "$default_focus_precedence": 3
                    }
                  },
                  {
                    "btn_8@action_form_panels.button_panel": {
                      "collection_index": 8,
                      
                      "$default_text": "(#form_button_text)",
                      "$hover_text": "('§l§e' + #form_button_text)",
                      "$focus_identifier": "null3_button_focus_id",
                      "$default_focus_precedence": 2
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },


  "shop_panel_buttons@action_form_buttons.buttons_template": {
    "$offset": [ 0, -2 ],
    "controls": [
      {
        "default_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "default_image": {
                "type": "image",
                "texture": "$default_button_texture"
              }
            },
            {
              "default_text": {
                "type": "label",
                "text": "#text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons",
                    "binding_name": "#form_button_text"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "$default_text",
                    "target_property_name": "#text"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "hover_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "hover_image": {
                "type": "image",
                "texture": "$hover_button_texture"
              }
            },
            {
              "hover_border_image": {
                "type": "image",
                "texture": "$button_light_borders",
                "layer": 32
              }
            },
            {
              "hover_text": {
                "type": "label",
                "text": "#text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons",
                    "binding_name": "#form_button_text"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "$hover_text",
                    "target_property_name": "#text"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "pressed_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "pressed_image": {
                "type": "image",
                "texture": "$pressed_button_texture"
              }
            },
            {
              "pressed_border_image": {
                "type": "image",
                "texture": "$button_light_borders",
                "layer": 32
              }
            },
            {
              "pressed_text": {
                "type": "label",
                "text": "#text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons",
                    "binding_name": "#form_button_text"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "$hover_text",
                    "target_property_name": "#text"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}