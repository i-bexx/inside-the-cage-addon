{
  "namespace": "question_panel",

  "question_panel_container" : {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      { "button_creator@question_panel.button_creator": {} }
    ]
  },

  "button_creator": {
    "type": "grid",
    "size": [180, "100%c"],
    "anchor_from": "center",
    "anchor_to": "center",

    "$padding_size": [180, 52],

    "focus_container": true,
    "focus_navigation_mode_left": "contained",
    "focus_navigation_mode_right": "contained",
    
    "grid_dimensions": [1, 2],
    "maximum_grid_items": 2,
    "grid_item_template": "action_form_panels.button_panel_small",
    "collection_name": "form_buttons"
  }
}