{
  "namespace": "random_peep_panel",

  // --- Main Elements ---

  "conversation_part_container": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#form_text",
        "source_property_name": "(#form_text = 'conversation_part')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "close_button_container@server_form_main_templates.close_button_container": {
          "offset": [ -7, -7 ]
        }
      },
      {
        "next_button_panel": {
          "type": "collection_panel",
          "size": [ 50, 20 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [ -5, 10 ],
          "layer": 7,

          "property_bag": {
            "#one": 1
          },
          "factory": {
            "name": "next_button_factory",
            "control_name": "random_peep_panel.choice_button"
          },
          "collection_name": "form_buttons",

          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "#one",
              "target_property_name": "#collection_length"
            }
          ]
        }
      },
      {
        "conversation_grid": {
          "type": "grid",
          "size": [ "100%", "100%c" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [ 0, 5 ],
          "maximum_grid_items": 3,
          "grid_dimensions": [ 1, 3 ],
          "grid_item_template": "random_peep_panel.conversation_text_panel",
          "collection_name": "form_buttons"
        }
      }
    ]
  },

  "question_part_container": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#form_text",
        "source_property_name": "(#form_text = 'question_part')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "yes_button_container": {
          "type": "collection_panel",
          "size": [ 50, 20 ],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "offset": [ -5, -10 ],
          "layer": 7,
          "collection_name": "form_buttons",
          "controls": [
            {
              "yes_button_container_control": {
                "type": "collection_panel",
                "collection_index": 0,
                "controls": [
                  { "yes_button@choice_button": {} }
                ]
              }
            }
          ]
        }
      },
      {
        "no_button_container": {
          "type": "collection_panel",
          "size": [ 50, 20 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [ -5, 10 ],
          "layer": 7,
          "collection_name": "form_buttons",
          "controls": [
            {
              "no_button_container_control": {
                "type": "collection_panel",
                "collection_index": 1,
                "controls": [
                  {
                    "no_button@choice_button": {
                      "$default_focus_precedence": 1
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "question_text_creator": {
          "type": "collection_panel",
          "size": [ "100%", "100%c" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [ 0, 25 ],
          "collection_name": "form_buttons",
          "controls": [
            {
              "question_text@random_peep_panel.conversation_text_panel": {
                "collection_index": 2,
                "$anim_duration": 0.2
              }
            }
          ]
        }
      }
    ]
  },

  "farewell_part_container": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#form_text",
        "source_property_name": "(#form_text = 'farewell_part')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "close_button_container_farewell@server_form_main_templates.close_button_container_detailed": {
          "offset": [ -7, -7 ],
          "$focus_identifier": "random_peep_panel_close_button_focus_id",
          "$other_focus_container_name": "ok_button_panel"
        }
      },
      {
        "ok_button_container": {
          "type": "collection_panel",
          "size": [ 50, 20 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [ -5, 10 ],
          "layer": 7,
          "collection_name": "form_buttons",
          "controls": [
            {
              "ok_button_container_control": {
                "type": "collection_panel",
                "collection_index": 0,
                "controls": [
                  { "ok_button@choice_button": {} }
                ]
              }
            }
          ]
        }
      },
      {
        "conversation_grid": {
          "type": "grid",
          "size": [ "100%", "100%c" ],
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "offset": [ 0, 5 ],
          "$anim_duration": 0.4,
          "maximum_grid_items": 2,
          "grid_dimensions": [ 1, 2 ],
          "grid_item_template": "random_peep_panel.conversation_text_panel",
          "collection_name": "form_buttons"
        }
      }
    ]
  },

  "background": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/hud_tip_text_background",
    "alpha": 0.5,
    "layer": 5
  },

    // --- Text Creator ---

  "conversation_text_panel": {
    "type": "collection_panel",
    "size": [ "100%", 20 ],
    "layer": 6,
    "bindings": [
      {
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name": "#form_button_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#form_button_text = 'Next' or #form_button_text = 'Ok'))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "text": {
          "type": "label",
          "text": "#form_button_text",
          "anchor_from": "center",
          "anchor_to": "center",
          "bindings": [
            {
              "binding_type": "collection",
              "binding_collection_name": "form_buttons",
              "binding_name": "#form_button_text"
            }
          ]
        }
      },
      {
        "background": {
          "type": "image",
          "size": [ "100%sm + 14px", "100%sm" ],
          "texture": "textures/ui/Black",
          "anchor_from": "center",
          "anchor_to": "center",
          "clip_ratio": 0.0,
          "clip_direction": "right",
          "clip_pixelperfect": false,
          "$anim_duration|default": 2.0,
          "anims": [ "@random_peep_panel.wait_anim" ],
          "bindings": [
            {
              "binding_type": "view",
              "resolve_sibling_scope": true,
              "source_control_name": "text",
              "source_property_name": "(not (#form_button_text = ''))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

    // --- Button ---

  "choice_button@action_form_buttons.buttons_template": {
    "$button_text_anchors": "center",
    "$default_focus_precedence": 2
  },

    // --- Animations ---

  "wait_anim": {
    "anim_type": "wait",
    "duration": 0.5,
    "next": "@random_peep_panel.anim_clipout"
  },

  "anim_clipout": {
    "anim_type": "clip",
    "easing": "linear",
    "duration": "$anim_duration",
    "from": 0.0,
    "to": 1.0
  }
}