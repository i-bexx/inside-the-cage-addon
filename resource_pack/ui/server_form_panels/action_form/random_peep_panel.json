{
  "namespace": "random_peep_panel",

  "conversation_panel": {
    "type": "panel",
    "size": [ "100%", "20%" ],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "offset": [ 0, -20 ],
    "controls": [
      {
        "background": {
          "type": "image",
          "size": [ "100%", "100%" ],
          "texture": "textures/ui/hud_tip_text_background",
          "alpha": 0.5,
          "layer": 5
        }
      },
      {
        "close_button_container@server_form_main_templates.close_button_container_detailed": {
          "offset": [ -7, -7 ],
          "$focus_identifier": "random_peep_panel_close_button_focus_id",
          "$other_focus_container_name": "next_button_panel"
        }
      },
      {
        "next_button_panel": {
          "type": "collection_panel",
          "size": [ 50, 20 ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [ -5, 10 ],
          "layer": 7,

          "$button_text_anchors": "center",
          "$focus_identifier": "random_peep_panel_next_button_focus_id",
          "$default_focus_precedence": 2,

          "focus_container": true,
          "focus_container_custom_up": [
            {
              "other_focus_container_name": "close_button_container"
            }
          ],

          "property_bag": {
            "#one": 1
          },
          "factory": {
            "name": "next_button_factory",
            "control_name": "action_form_buttons.buttons_template"
          },
          "collection_name": "form_buttons",

          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "#one",
              "target_property_name": "#collection_length"
            }
          ]
        }
      },
      {
        "conversation_grid": {
          "type": "grid",
          "size": [ "100%", "100%c" ],
          "anchor_from": "center",
          "anchor_to": "center",
          "maximum_grid_items": 3,
          "grid_dimensions": [ 1, 3 ],
          "grid_item_template": "random_peep_panel.conversation_text_panel",
          "collection_name": "form_buttons"
        }
      }
    ]
  },

  "conversation_text_panel": {
    "type": "panel",
    "size": [ "100%", 30 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "offset": [ 0, -10 ],
    "layer": 6,
    "bindings": [
      {
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name": "#form_button_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#form_button_text = 'Next'))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "text": {
          "type": "label",
          "text": "#form_button_text",
          "anchor_from": "center",
          "anchor_to": "center",
          "bindings": [
            {
              "binding_type": "collection",
              "binding_collection_name": "form_buttons",
              "binding_name": "#form_button_text"
            }
          ]
        }
      },
      {
        "background": {
          "type": "image",
          "size": [ "100%sm + 14px", "100%sm" ],
          "texture": "textures/ui/Black",
          "anchor_from": "center",
          "anchor_to": "center",
          "clip_ratio": 0.0,
          "clip_direction": "right",
          "clip_pixelperfect": false,
          "anims": [ "@random_peep_panel.wait_anim" ],
          "bindings": [
            {
              "binding_type": "view",
              "resolve_sibling_scope": true,
              "source_control_name": "text",
              "source_property_name": "(not (#form_button_text = ''))",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "wait_anim": {
    "anim_type": "wait",
    "duration": 0.5,
    "next": "@random_peep_panel.anim_clipout"
  },

  "anim_clipout": {
    "anim_type": "clip",
    "easing": "linear",
    "duration": 5,
    "from": 0.0,
    "to": 1.0
  }
}