{
  "namespace": "server_form_main_templates",

  // --- CLOSE BUTTONS ---

  "close_button_container": {
    "type": "panel",
    "offset": [8, -8],
    "layer": 64,

    "$focus_identifier|default": "",
    "focus_container": true,
    "focus_navigation_mode_right": "stop",
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_up": "stop",
    "controls": [
      {
        "close_button": {
          "type": "button",
          "$close_button_size|default": [14, 14],
          "$close_button_anchor|default": "top_right",
          "size": "$close_button_size",
          "anchor_from": "$close_button_anchor",
          "anchor_to": "$close_button_anchor",
          "sound_name": "random.click",

          "default_control": "default_state",
          "hover_control": "hover_state",
          "pressed_control": "pressed_state",

          "focus_enabled": true,
          "default_focus_precedence": 1,
          "focus_identifier": "$focus_identifier",

          "$default_texture|default": "textures/ui/panels/main_panel/close_button",
          "$hover_texture|default": "textures/ui/panels/main_panel/close_button_hover",
          
          "$alpha|default": 1,
          "$size|default": [16, 16],
          "button_mappings": [
            {
              "mapping_type": "pressed",
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit"
            },
            {
              "mapping_type": "focused",
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.menu_exit"
            }
          ],
          "controls": [
            {
              "background_image@server_form_main_templates.background_image": {
                  "alpha": 1
              }
            },
            {
              "default_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$default_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "hover_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "pressed_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            }
          ]
        }
      }
    ]
  },

  "close_button_container_detailed@close_button_container": {
    "$other_focus_container_name|default": "",
    "focus_navigation_mode_down": "custom",
    "focus_container_custom_down": [
      {
        "other_focus_container_name": "$other_focus_container_name"
      }
    ]
  },

  // --- FORM DRAWER ELEMENTS ---

  "form_panel_drawer": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "$container_name|default": "button_panel",
    "$container_reference|default": "action_form_panels.button_panel",
    "$hide_form_body|default": false,
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      {
        "form_body@server_form_main_templates.form_body": {
          "ignored": "$hide_form_body"
        }
      },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "$container_name@$container_reference": {} }
    ]
  },

  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "$text_name|default": "long_text",
    "$text_name_reference|default": "server_form_main_templates.long_text",
    "layer": 5,
    "controls": [
      { 
        "background_image@server_form_main_templates.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "$text_name@$text_name_reference": {} }
    ]
  },



  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "$texture|default": "textures/ui/panels/main_panel/background",
    "texture": "$texture",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "long_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  },

  "custom_text": {
    "type": "label",
    "text": "#custom_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#custom_text"
      }
    ]
  },

  "hover_text_renderer": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "layer": 128,
    "allow_clipping": false,

    "$custom_hover_text|default": "",
    "$show_hover_text_renderer|default": false,

    "property_bag": {
      "#text_value": "$custom_hover_text",
      "#render_hover_text": "$show_hover_text_renderer"
    },
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "#text_value",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "#render_hover_text",
        "target_property_name": "#visible"
      }
    ]
  },


  // --- SCROLL PANEL ---

  "scroll_track_image": {
    "type": "image",
    "texture": "textures/ui/panels/ScrollRail",
    "alpha": 0.3
  },

  "scrollbar_box_image": {
    "type": "image",
    "texture": "textures/ui/panels/ScrollHandle",
    "alpha": "@server_form_main_templates.anim_scrollbar_box_fadeout"
  },

  "anim_scrollbar_box_fadeout": {
    "anim_type": "alpha",
    "play_event": "scrollbar.released",
    "reset_event": "scrollbar.active",
    "easing": "in_sine",
    "duration": 1.5,
    "from": 1,
    "to": 0,
    "next": "@server_form_main_templates.anim_scrollbar_box_fadeout"
  },



  "scroll_view": {
    "type": "scroll_view",
    "size": [ "100% - 4px", "100% - 2px" ],
    "anchor_from": "center",
    "anchor_to": "center",
    "offset": [ 4, 0 ],

    "always_listen_to_input": true,
    "always_handle_pointer": true,
    "consume_hover_events": true,

    "allow_scroll_even_when_content_fits": true,
    "scrollbar_track_button": "button.scrollbar_skip_track",
    "scrollbar_touch_button": "button.scrollbar_touch",
    "scroll_speed": 15,
    "touch_mode": "$touch",
    "gesture_control_enabled": true,
    "always_handle_scrolling": true,
    "scrollbar_track": "track",
    "scrollbar_box": "box",
    "scroll_box_and_track_panel": "scroll_box_and_track",
    "scroll_view_port": "scrolling_view_port",
    "scroll_content": "scrolling_content",

    "button_mappings": [
      {
        "mapping_type": "pressed",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.scrollbar_touch",
        "button_up_right_of_first_refusal": true
      }
    ],
    
    "controls": [
      {
        "layout_stack": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": [ "100%", "100%" ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            {
              "scrolling_view_port": {
                "type": "panel",
                "size": [ "fill", "100%" ],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "layer": 1,
                "clips_children": true,

                "controls": [
                  {
                    "scrolling_content@$scrolling_content": {
                      "anchor_from": "top_left",
                      "anchor_to": "top_left",
                      "layer": 1
                    }
                  }
                ]
              }
            },
            {
              "scroll_box_and_track": {
                "type": "panel",
                "size": [ "100%c", "100%" ],
                "clips_children": true,
                "controls": [
                  {
                    "scroll_bar_stack": {
                      "type": "stack_panel",
                      "orientation": "horizontal",
                      "size": [ "default", "100%" ],
                      "anchor_from": "center",
                      "anchor_to": "center",
                      "controls": [
                        {
                          "padding_1": {
                            "type": "panel",
                            "size": [ 2, 0 ]
                          }
                        },
                        {
                          "non_centered_panel": {
                            "type": "panel",
                            "size": [ "100%c", "100%" ],
                            "controls": [
                              {
                                "centered_panel": {
                                  "type": "panel",
                                  "size": [ "100%cm + 4px", "100% - 4px" ],
                                  "anchor_from": "center",
                                  "anchor_to": "center",
                                  "controls": [
                                    {
                                      "track": {
                                        "type": "scroll_track",
                                        "size": [ 5, "100%" ],
                                        "anchor_to": "center",
                                        "anchor_from": "center",
                                        "layer": 2,

                                        "controls": [
                                          { "bar_indent@server_form_main_templates.scroll_track_image": {} }
                                        ],
                                        "button_mappings": [
                                          {
                                            "mapping_type": "pressed",
                                            "from_button_id": "button.menu_select",
                                            "to_button_id": "button.scrollbar_skip_track"
                                          }
                                        ]
                                      }
                                    },
                                    {
                                      "box": {
                                        "type": "scrollbar_box",
                                        "size": [ 6, "100%" ],
                                        "anchor_to": "top_middle",
                                        "anchor_from": "top_middle",
                                        "layer": 5,
                                        "contained": true,
                                        "draggable": "vertical",

                                        "controls": [
                                          { "scrollbar_box_image@server_form_main_templates.scrollbar_box_image": {} }
                                        ],
                                        "button_mappings": [
                                          {
                                            "mapping_type": "pressed",
                                            "from_button_id": "button.menu_select",
                                            "to_button_id": "button.menu_select",
                                            "button_up_right_of_first_refusal": true
                                          }
                                        ]
                                      }
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        },
                        {
                          "padding_2": {
                            "type": "panel",
                            "size": [ 2, 0 ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}