{
  "namespace": "password_panel",

  "password_panel_container": {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "scroll_view@server_form_main_templates.scroll_view": {
          "$scrolling_content": "password_panel.custom_form_scrolling_content"
        }
      }
    ]
  },

  "custom_form_scrolling_content": {
    "type": "stack_panel",
    "size": [ "100% - 4px", "100%c" ],
    "offset": [ 2, 0 ],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",

    "controls": [
      // { "generated_form@server_form.generated_contents": {} }
      {
        "password_text_field_factory": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": [ "100% - 8px", "100%c" ],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "collection_name": "custom_form",

          "focus_container": true,

          "factory": {
            "name": "custom_form_factory",
            "control_ids": {
              "input": "@password_panel.password_elements" 
            }
          },

          "bindings": [
            {
              "binding_name": "#custom_form_length",
              "binding_name_override": "#collection_length"
            }
          ]
        }
      },
      {
        "top_padding": {
          "type": "panel",
          "size": [ "100%", 10 ]
        }
      },
      { "password_submit_button@modal_form_buttons.submit_button": {} },
      {
        "bottom_padding": {
          "type": "panel",
          "size": [ "100%", 6 ]
        }
      }
    ]
  },


  "password_elements@modal_form_panels.text_field_panel": {}
}