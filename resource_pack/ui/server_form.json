{
  "namespace": "server_form",

  "main_screen_content": {
    "type": "panel",
    "size": [0, 0],
    "controls": [
        {
          "server_form_factory": {
              "type": "factory",
              "control_ids": {
              "long_form": "@server_form.long_form",
              "custom_form": "@server_form.custom_form"
          }
        }
      }
    ]
  },

  "long_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      { "main_panel@server_form.main_panel": {} },
      { "shop_panel@server_form.shop_panel": {} },
      { "vote_panel@server_form.vote_panel": {} },
      { "question_panel@server_form.question_panel": {} },

      { "other_panels@server_form.other_panels": {} }
    ]   
  },

  "custom_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "$text_name": "custom_text",
    "$text_name_reference": "server_form_main_templates.custom_text",
    "controls": [
      { "password_panel@server_form.password_panel": {} }
    ]   
  },


  // LONG FORM PANELS

  "main_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'MAIN PANEL')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "background_image@server_form_main_templates.background_image": {} },
            { "label_text@server_form_main_templates.label_text": {} },
            {
              "form_panel_drawer@server_form_main_templates.form_panel_drawer": {
                "$container_name": "main_panel_container",
                "$container_reference": "main_panel.main_panel_container"
              }
            },
            {
              "close_button_container_detailed@server_form_main_templates.close_button_container_detailed": {
                "$focus_identifier": "main_panel_close_button_focus_id",
                "$other_focus_container_name": "main_shop_button"
              }
            }
          ]
        }
      }
    ]
  },
  
  "shop_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'SHOP')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "label_text@server_form_main_templates.label_text": {} },
            { "background_image@server_form_main_templates.background_image": {} },
            {
              "form_panel_drawer@server_form_main_templates.form_panel_drawer": {
                "$container_name": "shop_panel_container",
                "$container_reference": "shop_panel.shop_panel_container"
              }
            },
            {
              "close_button_container_detailed@server_form_main_templates.close_button_container_detailed": {
                "$focus_identifier": "shop_panel_close_button_focus_id",
                "$other_focus_container_name": "shop_button_container_1"
              }
            }
          ]
        }
      }
    ]
  },

  "vote_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'VOTE PANEL')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "label_text@server_form_main_templates.label_text": {} },
            { "background_image@server_form_main_templates.background_image": {} },
            {
              "form_panel_drawer@server_form_main_templates.form_panel_drawer": {
                "$container_name": "vote_panel_container",
                "$container_reference": "vote_panel.vote_panel_container"
              }
            },
            {
              "close_button_container@server_form_main_templates.close_button_container": {
                "$focus_identifier": "vote_panel_button_focus_id"
              }
            }
          ]
        }
      }
    ]
  },

  "question_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "$two_button_question_prefix|default": "Do you want to",
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#form_text",
        "source_property_name": "(%.14s * #form_text = $two_button_question_prefix)",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "background_image@server_form_main_templates.background_image": {} },
            {
              "form_panel_drawer@server_form_main_templates.form_panel_drawer": {
                "$container_name": "question_panel_container",
                "$container_reference": "question_panel.question_panel_container"
              }
            },
            {
              "close_button_container@server_form_main_templates.close_button_container": {
                "$focus_identifier": "question_panel_button_focus_id"
              }
            }
          ]
        }
      }
    ]
  },

  "other_panels@common_dialogs.main_panel_no_buttons": {
    "$title_panel": "common_dialogs.standard_title_label",
    "$title_size": [ "100% - 15px", 10 ],
    "$title_max_size": [ "100% - 15px", 10 ],
    "size": [225, 200],
    "$text_name": "#title_text",
    "$title_text_binding_type": "none",
    "$child_control": "server_form.long_form_panel",
    "layer": 2,
    "bindings": [
      {
        "binding_name": "#title_text"
      },
      {
        "binding_name": "#form_text"
      },
      {
        
        "binding_type": "view",
        "source_property_name": "(#title_text = '' and #form_text = '')",
        "target_property_name": "#visible"
      }
    ]
  },

  // CUSTOM FORM PANELS

  "password_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'PASSWORD PANEL')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      { "background_image@server_form_main_templates.background_image": {} },
      { "label_text@server_form_main_templates.label_text": {} },
      {
        "form_panel_drawer@server_form_main_templates.form_panel_drawer": {
          "$container_name": "password_panel_container",
          "$container_reference": "password_panel.password_panel_container",

          "$text_name": "custom_text",
          "$text_name_reference": "server_form_main_templates.custom_text"
        }
      },
      {
        "close_button_container_detailed@server_form_main_templates.close_button_container_detailed": {
          "$focus_identifier": "password_panel_close_button_focus_id",
          "$default_focus_precedence": 1,
          "$other_focus_container_name": "password_text_field_factory"
        }
      }
    ]
  }
}