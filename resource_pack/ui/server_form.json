{
  "namespace": "server_form",

  "main_screen_content": {
    "type": "panel",
    "size": [0, 0],
    "controls": [
        {
          "server_form_factory": {
              "type": "factory",
              "control_ids": {
              "long_form": "@server_form.long_form",
              "custom_form": "@server_form.custom_form"
          }
        }
      }
    ]
  },

  "long_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      { "main_panel@server_form.main_panel": {} },
      { "shop_panel@server_form.shop_panel": {} },
      { "other_panels@server_form.other_panels": {} }
    ]   
  },

  "other_panels@common_dialogs.main_panel_no_buttons": {
    "$title_panel": "common_dialogs.standard_title_label",
    "$title_size": [ "100% - 15px", 10 ],
    "$title_max_size": [ "100% - 15px", 10 ],
    "size": [225, 200],
    "$text_name": "#title_text",
    "$title_text_binding_type": "none",
    "$child_control": "server_form.long_form_panel",
    "layer": 2,
    "bindings": [
      {
        "binding_name": "#title_text",
        "binding_type": "view",
        "source_property_name": "(not (#title_text = 'MAIN PANEL') and (not (#title_text = 'SHOP')) and (not (#title_text = 'VOTE PANEL')))",
        "target_property_name": "#visible"
      }
    ]
  },

  "main_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_name": "#title_text",
        "binding_type": "view",
        "source_property_name": "(#title_text = 'MAIN PANEL')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "label_text@main_panel.label_text": {} },
            { "background_image@main_panel.background_image": {} },
            { "content_stack@main_panel.content_stack": {} },
            {
              "close_button@main_panel.close_button": {
                "offset": [8, -8],
                "layer": 64
              }
            }
          ]
        }
      }
    ]
  },
  
  "shop_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'SHOP')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "label_text@shop_panel.label_text": {} },
            { "background_image@shop_panel.background_image": {} },
            { "content_stack@shop_panel.content_stack": {} },
            {
              "close_button@shop_panel.close_button": {
                "offset": [8, -8],
                "layer": 64
              }
            }
          ]
        }
      }
    ]
  },

  "voting_panel": {
    "type": "panel",
    "size": [284, 190],
    "layer": 2,
    "bindings": [
      {
        "binding_type": "view",
        "binding_name": "#title_text",
        "source_property_name": "(#title_text = 'VOTE PANEL')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "indent_panel": {
          "type": "panel",
          "size": ["100%", "100%"],
          "controls": [
            { "label_text@vote_panel.label_text": {} },
            { "background_image@vote_panel.background_image": {} },
            { "content_stack@vote_panel.content_stack": {} },
            {
              "close_button@vote_panel.close_button": {
                "offset": [8, -8],
                "layer": 64
              }
            }
          ]
        }
      }
    ]
  }
}