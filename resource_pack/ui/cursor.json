{
  "namespace": "cursor",

  "cursor_states": {
    "type": "panel",
    "size": [7, 7],
    "anchor_from": "center",
    "anchor_to": "center",
    "alpha": 0.7,
    "propagate_alpha": true,
    "controls": [
      { "@cursor.cursor_normal": {} },
      { "@cursor.cursor_green": {} },
      { "@cursor.cursor_blue": {} },
      { "@cursor.cursor_red": {} },

      { "@cursor.hitmarker": {} }
    ]
  },

  "hitmarker": {
    "type": "image",
    "size": [44, 44],
    "offset": [-1, 5],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/hitmarker",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_x3')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_normal": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/cursor_normal",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_00' or %.14s * #hud_subtitle_text_string = 'cursorState_x0')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_green": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/cursor_green",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_01' or %.14s * #hud_subtitle_text_string = 'cursorState_x1')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_blue": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/cursor_blue",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_02' or %.14s * #hud_subtitle_text_string = 'cursorState_x2')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_red": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/cursor_red",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_03' or %.14s * #hud_subtitle_text_string = 'cursorState_x3')",
        "target_property_name": "#visible"
      }
    ]
  }
}