{
  "namespace": "cursor",

  "cursor_states": {
    "type": "panel",
    "size": [10, 10],
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      { "@cursor.cursor_normal": {} },
      { "@cursor.cursor_green": {} },
      { "@cursor.cursor_blue": {} },
      { "@cursor.cursor_red": {} }
    ]
  },

  "cursor_normal": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/cursors/cursor_normal",
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string = 'cursorState_00')",
        "target_property_name": "#visible"
      }
    ]
  },

