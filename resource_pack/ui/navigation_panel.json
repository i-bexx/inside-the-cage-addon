{
  "namespace": "navigation_panel",

  "navigation_panel_parent": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      { "@navigation_panel.navigation_panel_child": {} }
    ]
  },

  "navigation_panel_child": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "offset": [-10, 5],
    "controls": [
      { "@coordinates.coordinates_panel": {} },
      {
        "space": {
          "type": "panel",
          "size": [5, 0]
        }
      },
      { "@compass.dynamic_compass": {} }
    ]
  }
}