    "anim_type": "wait",
    "duration": 10,
    "next": "@sanity_detailed.brain_animation_up"
  },
  "brain_animation_up": {
    "anim_type": "offset",
    "from": [0, 0],
    "to": [0, -4],
    "duration": 0.0,
    "next": "@sanity_detailed.brain_animation_wait_up"
  },
  "brain_animation_wait_up": {
    "anim_type": "wait",
    "duration": 0.1,
    "next": "@sanity_detailed.brain_animation_down"
  },
  "brain_animation_down": {
    "anim_type": "offset",
    "from": [0, -4],
    "to": [0, 0],
    "duration": 0.0,
    "next": "@sanity_detailed.brain_animation_wait_down"
  },
  "brain_animation_wait_down": {
