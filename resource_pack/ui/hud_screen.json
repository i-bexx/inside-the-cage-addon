{
  "namespace": "hud",

  "hud_title_text": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "title_frame"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "subtitle_frame"
      }
    ]
  },

  "progress_text_label": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "remove",
        "where": {
          "binding_name": "#level_number_visible"
        }
      }
    ]
  },

  "screen_left_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [ "40%", "100%" ],
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "controls": [
      {
        "paper_doll_padding": {
          "type": "panel",
          "size": [ "100%", 50 ],
          "bindings": [
            {
              "binding_name": "#paper_doll_visible",
              "binding_name_override": "#visible"
            }
          ]
        }
      },
      {
        "non_centered_gui_padding": {
          "type": "panel",
          "size": [ "100%", 32 ],
          "bindings": [
            {
              "binding_name": "#hud_visible_not_centered",
              "binding_name_override": "#visible",
              "binding_type": "global"
            }
          ]
        }
      },
      { "number_of_days_played@hud.number_of_days_played": {} },
      { "souls_freed_counter@souls_freed_counter.souls_freed_counter": {} },
      {
        "game_tip@game_tip.game_tip_chat_stack_factory": {
          "size": [ "100%", "100%c" ]
        }
      },
      {
        "chat": {
          "type": "panel",
          "size": ["100%", "25%"],
          "controls": [
            { "chat_panel@chat.chat_panel": {} }
          ]
        }
      }
    ]
  },

  //Classic PC UI
  "centered_gui_elements_at_bottom_middle": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_1"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "armor_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "hunger_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_1"
      }
    ]
  },

  //Pocket UI
  "not_centered_gui_elements": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "armor_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "hunger_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_1"
      }
    ]
  },

  //Classic Pocket UI 
  "centered_gui_elements_at_bottom_middle_touch": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_1"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "armor_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "hunger_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_1"
      }
    ]
  },

  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "chat_stack"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "sidebar"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "curor_rend" // This child element renders itself if the binding values are NOT met
      },
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
            { 
              "coin_panel@coin.coin_panel": {
                "layer": 1
              } 
            },
            {
              "screen_left_stack@hud.screen_left_stack": {
                "layer": 2
            } 
          },
          {
            "@sanity_information_text.sanity_screen": {
              "layer": 3
            }
          },
          {
            "@sanity_detailed.sanity_detailed_screen": {
              "layer": 3
            }
          },
          {
            "@navigation_panel.navigation_panel_parent": {
              "layer": 4
            }
          },
          {
            "@notification.notification_text": {
              "layer": 5
            }
          },
          {
            "cursor_main": {
              "type": "custom",
              "size": [ 16, 16 ],
              "renderer": "cursor_renderer",
              "layer": 4,
              "bindings": [
                {
                  "binding_type": "global",
                  "binding_name": "#hud_subtitle_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((%.1s * #hud_subtitle_text_string = ' ') or (#hud_subtitle_text_string = ''))",
                  "target_property_name": "#visible"
                }
              ]
            }
          },
          {
            "@custom_cursor.custom_cursor_states": {
              "layer": 500
            }
          }
        ]
      }
    ]
  }
}