{
  "namespace": "hud",

  // Paper Doll Renderer
  "hud_player_renderer": {
    "type": "panel",
    "size": [ 0, 0 ],

    "controls": [
      {
        "hud_player": {
          "type": "custom",
          "renderer": "hud_player_renderer",
          "layer": 1,
          "animation_reset_name": "screen_animation_reset",
          "anims": [
            "@common.screen_exit_size_animation_push",
            "@common.screen_exit_size_animation_pop",
            "@common.screen_entrance_size_animation_push",
            "@common.screen_entrance_size_animation_pop"
          ],
          "bindings": [
            {
              "binding_name": "#paper_doll_visible",
              "binding_name_override": "#visible"
            }
          ]
        }
      }
    ]
  },

  "screen_middle_left_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [ "40%", "100%" ],
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "controls": [
      { "mini_player_container@mini_player.mini_player_container": {} },
      {
        "padding": {
          "type": "panel",
          "size": [ "100%", 10 ]
        }
      },
      { "souls_freed_counter_container@souls_freed_counter.souls_freed_counter_container": {} },
      {
        "padding": {
          "type": "panel",
          "size": [ "100%", 10 ]
        }
      },
      {
        "game_tip@game_tip.game_tip_chat_stack_factory": {
          "size": [ "100%", "100%c" ]
        }
      },
      {
        "padding": {
          "type": "panel",
          "size": [ "100%", 10 ]
        }
      },
      {
        "chat": {
          "type": "panel",
          "size": ["100%", "25%"],
          "controls": [
            { "chat_panel@chat.chat_panel": {} }
          ]
        }
      }
    ]
  },

  "hud_title_text": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "title_frame"
      },
      {
        "array_name" : "controls",
        "operation" : "remove",
        "control_name" : "subtitle_frame"
      }
    ]
  },

  "progress_text_label": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "remove",
        "where": {
          "binding_name": "#level_number_visible"
        }
      }
    ]
  },

  //Classic PC UI
  "centered_gui_elements_at_bottom_middle": {
    "size": "$size",
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "variables": [
      {
        "requires": "($pocket_edition)",
        "$size": [ 200, 50 ]
      },
      {
        "requires": "(not $pocket_edition)",
        "$size": [ 180, 50 ]
      }
    ],
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "remove",
        "where": {
          "binding_name": "#hud_visible_centered"
        }
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "horse_heart_rend_1"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "armor_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "hunger_rend"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_0"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "bubbles_rend_1"
      },
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
          {
            "@stamina_bar.stamina_bar": {
              "offset": [ -40, 13 ],
              "anchor_from": "bottom_right",
              "anchor_to": "bottom_right"
            }
          }
        ]
      }
    ]
  },

  "root_panel": {
    "modifications": [
      { //Classic UI (for Pocket Edition)
        "array_name": "controls",
        "operation": "remove",
        "control_name": "centered_gui_elements_at_bottom_middle_touch"
      },
      { //Pocket UI
        "array_name": "controls",
        "operation": "remove",
        "control_name": "not_centered_gui_elements"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "chat_stack"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "sidebar"
      },
      {
        "array_name": "controls",
        "operation": "remove",
        "control_name": "curor_rend" // This child element renders itself if the binding values are NOT met
      },
      {
        "array_name": "controls",
        "operation": "insert_front",
        "value": [
            { 
              "@coin.coin_panel": {
                "layer": 10
              } 
            },
            {
            "@navigation_panel.navigation_panel_parent": {
                "layer": 20
              }
            },
            {
              "@hud.screen_middle_left_stack": {
                "layer": 30
              } 
            },
            {
              "@notification.notification_text": {
                "layer": 50
              }
            },
            {
              "@cursors.cursor_main": {
                "layer": 600
              }
            },
            {
              "@cursors.gun_cursor_states": {
                "layer": 600
              }
            }
        ]
      }
    ]
  }
}