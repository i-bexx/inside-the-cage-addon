{
  "namespace": "mini_player",

  "mini_player_container": {
    "type": "panel",
    "size": [ "100%y", "20%" ],
    "controls": [
      {
        "mini_player_stack@mini_player.mini_player_stack": {}
      }
    ]
  },

  "mini_player_stack": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": [ "100%", "100%" ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [ 5, 5 ],
    "controls": [
      { "mini_player_panel@mini_player.mini_player_panel": {} },
      {
        "space": {
          "type": "panel",
          "size": [ 5, 0 ]
        }
      },
      {
        "sanity_panel": {
          "type": "panel",
          "size": ["100%c", "100%"],
          "controls": [
            {
              "sanity_screen@sanity_information_text.sanity_screen": {
                "anchor_from": "top_middle",
                "anchor_to": "top_middle"
              }
            }
          ]
        }
      }
    ]
  },


  "mini_player_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "clips_children": true,
    "controls": [
      {
        "mini_player_background@mini_player.mini_player_background": {}
      },
      {
        "sanity_frame@sanity_detailed.sanity_detailed_screen": {}
      }
    ]
  },

  "mini_player_background": {
    "type": "image",
    "size": [ "100%", "100%" ],
    "texture": "textures/ui/mini_player/background",
    "alpha": 0.4,
    "clips_children": true,
    "controls": [
      {
        "mini_player_renderer@mini_player.mini_player_renderer": {}
      }
    ]
  },

  "mini_player_renderer": {
    "type": "custom",
    "renderer": "live_player_renderer",
    "size": [ "85%", "85%" ],
    "offset": [ 0, 5 ]
  }
}