{
  "namespace": "sanity_information_text",

  "sanity_screen": {
    "type": "image",
    "texture": "textures/ui/hud_tip_text_background",
    "min_size": ["20px", "5px"],
    "size": ["100%c + 10px", "100%c - 10px"],
    "alpha": 0.4,
    "property_bag": {
      "#sanity_string": "sanityUIx"
    },
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hide_in_round_personal_ui"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.9s * #hud_title_text_string)",
        "target_property_name": "#sanity_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#sanity_string = 'sanityUIx') or (#sanity_string = ''))",
        "target_property_name": "#hide_in_round_personal_ui"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not #hide_in_round_personal_ui)",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      { "sanity_panel@sanity_information_text.sanity_panel": {} }
    ]
  },


  "sanity_panel": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": [ "100%c", "100%c" ],
    "offset": [ 0, 10 ],
    "controls": [
      { "@sanity_information_text.sanity_objective": {} },
      {
        "colon": {
          "type": "label",
          "text": ":",
          "size": ["default", "default"]
        }
      },
      {
        "space": {
          "type": "panel",
          "size": [4, 0]
        }
      },
      { "@sanity_information_text.sanity_value": {} }
    ]
  },

  "sanity_objective": {
    "type": "label",
    "text": "Sanity",
    "size": ["default", "default"]
  },

  "sanity_value": {
    "type": "panel",
    "size": [ "100%c", "100%c" ],
    "controls": [
      { 
        "is_stable": {
            "type": "label",
            "text": "STABLE",
            "color": [ 0.0, 0.0, 0.7 ],
            "bindings": [
                {
                  "binding_type": "view",
                  "source_control_name": "sanity_screen",
                  "source_property_name": "((#sanity_string = 'sanityUI1') or (#sanity_string = 'sanityUI2'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      },
      { 
        "is_normal": {
            "type": "label",
            "text": "NORMAL",
            "color": [ 0.7, 0.7, 0.0 ],
            "bindings": [
                {
                  "binding_type": "view",
                  "source_control_name": "sanity_screen",
                  "source_property_name": "((#sanity_string = 'sanityUI3') or (#sanity_string = 'sanityUI4'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      },
      { 
        "is_poor": {
            "type": "label",
            "text": "POOR",
            "color": [ 0.7, 0.0, 0.0 ],
            "bindings": [
                {
                  "binding_type": "view",
                  "source_control_name": "sanity_screen",
                  "source_property_name": "((#sanity_string = 'sanityUI5') or (#sanity_string = 'sanityUI6') or (#sanity_string = 'sanityUI7'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      }
    ]
  }
}