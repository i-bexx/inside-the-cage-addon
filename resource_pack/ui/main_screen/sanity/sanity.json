{
  "namespace": "sanity_information_text",

  "sanity_screen": {
    "type": "image",
    "texture": "textures/ui/hud_tip_text_background",
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "offset": [5, -2],  
    "min_size": ["20px", "5px"],
    "size": ["100%c + 10px", "100%c - 10px"],
    "alpha": 0.4,
    "bindings": [
      {
        "binding_name": "#hud_title_text_string"
      },
      {
        "binding_name": "#hide_in_round_personal_ui"
      },
      {
        "binding_type": "view",
        "source_property_name": "((%.9s * #hud_title_text_string = 'sanityUIx') or (%.9s * #hud_title_text_string = ''))",
        "target_property_name": "#hide_in_round_personal_ui"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not #hide_in_round_personal_ui)",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      { 
        "@sanity_information_text.sanity_panel": {
          "offset": ["0px", "10px"]
        } 
      }
    ]
  },

  "sanity_panel": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": ["100%c", "100%c"],
    "controls": [
      { "@sanity_information_text.sanity_objective": {} },
      
      {
        "colon": {
          "type": "label",
          "text": ":",
          "size": ["default", "default"]
        }
      },

      {
        "space": {
          "type": "panel",
          "size": [4, 0]
        }
      },

      { "@sanity_information_text.sanity_value": {} }
    ]
  },

  "sanity_objective": {
    "type": "label",
    "text": "Sanity",
    "size": ["default", "default"]
  },
  "sanity_value": {
    "type": "panel",
    "size": [ "100%c", "100%c" ],
    "controls": [
      { 
        "is_stable": {
            "type": "label",
            "text": "STABLE",
            "color": [ 0.0, 0.0, 0.7 ],
            "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((%.9s * #hud_title_text_string = 'sanityUI1') or (%.9s * #hud_title_text_string = 'sanityUI2'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      },
      { 
        "is_normal": {
            "type": "label",
            "text": "NORMAL",
            "color": [ 0.7, 0.7, 0.0 ],
            "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((%.9s * #hud_title_text_string = 'sanityUI3') or (%.9s * #hud_title_text_string = 'sanityUI4'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      },
      { 
        "is_poor": {
            "type": "label",
            "text": "POOR",
            "color": [ 0.7, 0.0, 0.0 ],
            "bindings": [
                {
                  "binding_name": "#hud_title_text_string"
                },
                {
                  "binding_type": "view",
                  "source_property_name": "((%.9s * #hud_title_text_string = 'sanityUI5') or (%.9s * #hud_title_text_string = 'sanityUI6') or (%.9s * #hud_title_text_string = 'sanityUI7'))",
                  "target_property_name": "#visible"
                }
            ]
        } 
      }
    ]
  }
}