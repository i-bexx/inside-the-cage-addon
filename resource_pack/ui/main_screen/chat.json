{
  "namespace": "chat",

  "anim_countdown_decrease": {
    "anim_type": "clip",
    "easing": "linear",
    "duration": "$chat_item_lifetime",
    "from": 0.0,
    "to": 1.0
  },
  
  "chat_panel": {
    "type": "panel",
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "size": [ "100%", "100%" ],

    "controls": [
      {
        "stack_panel": {
          "type": "stack_panel",
          "factory": {
            "name": "chat_item_factory",
            "max_children_size": 5,
            "control_ids": {
              "chat_item": "chat_item@chat.chat_grid_item"
            }
          }
        }
      }
    ]
  },

  "chat_grid_item": {
    "type": "panel",
    "layer": 1,
    "size": [ "100%-2px", "100%c" ],
    "bindings": [
      {
        "binding_name": "(not #on_new_death_screen)",
        "binding_name_override": "#visible"
      }
    ],
    "controls": [
      {
        "chat_background": {
          "type": "image",
          "texture": "textures/ui/Black",
          "alpha": "$chat_background_opacity",
          "size": [ "100%", "100%c" ],
          "anims": [
              "@hud.anim_chat_bg_wait"
          ],
          "controls": [
            {
              "content_organizer": {
                "type": "stack_panel",
                "orientation": "vertical",
                "size": [ "100%", "100%c" ],
                "controls": [
                    {
                      "chat_text@hud.chat_label": {
                          "anchor_from": "top_left",
                          "anchor_to": "top_left",
                          "offset": [ 2, 0 ]
                      }
                    },
                    {
                      "space_top": {
                          "type": "panel",
                          "size": [ "100%", 2 ],
                          "anims": [ "@hud.anim_chat_bg_wait" ]
                      }
                    },
                    {
                      "countdown": {
                          "type": "image",
                          "texture": "textures/ui/white",
                          "anchor_from": "top_left",
                          "anchor_to": "top_left",
                          "size": [ "100%", 1 ],
                          "clip_direction": "left",
                          "clip_pixelperfect": false,
                          "anims": [ "@chat.anim_countdown_decrease" ]
                      }
                    },
                    {
                      "space_bottom": {
                          "type": "panel",
                          "size": [ "100%", 3 ],
                          "alpha": 1,
                          "anims": [ "@hud.anim_chat_bg_wait" ]
                      }
                    }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}