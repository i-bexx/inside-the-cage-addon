{
  "namespace": "souls_freed_counter",

  "souls_freed_counter_container": {
    "type": "panel",
    "size": ["100%", "100%c"],
    "bindings": [
      {
        "binding_type": "collection",
        "binding_collection_name": "scoreboard_scores",
        "binding_name": "#player_score_sidebar"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#player_score_sidebar - §c) / 10)",
        "target_property_name": "#tens_place_result"
      }
    ],
    "controls": [
      { "souls_freed_counter@souls_freed_counter.souls_freed_counter": {} }
    ]
  },

  "souls_freed_counter": {
    "type": "image",
    "size": [ "100%c + 14px", 20 ],
    "anchor_from": "left_middle",
    "anchor_to": "left_middle",
    "texture": "textures/ui/hud_tip_text_background",
    "alpha": 0.7,
    "bindings": [
      {
        "binding_name": "#show_in_round_global_ui"
      },
      {
        "binding_type": "view",
        "source_control_name": "souls_freed_counter_container",
        "source_property_name": "(#tens_place_result < 9)",
        "target_property_name": "#show_in_round_global_ui"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#show_in_round_global_ui)",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "stack": {
          "type": "stack_panel",
          "orientation": "horizontal",
          "size": ["100%c", "50%"],
          "anchor_from": "center",
          "anchor_to": "center",
          "controls": [
            {
              "label_1": {
                "type": "label",
                "size": ["default", "default"],
                "text": "Souls Freed: "
              }
            },
            {
              "label_2": {
                "type": "label",
                "size": ["default", "default"],
                "text": "#text",
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "souls_freed_counter_container",
                    "source_property_name": "('§z' + #tens_place_result)",
                    "target_property_name": "#text"
                  }
                ]
              }
            },
            {
              "label_3": {
                "type": "label",
                "size": ["default", "default"],
                "text": "/7"
              }
            }
          ]
        }
      }
    ]
  }
}