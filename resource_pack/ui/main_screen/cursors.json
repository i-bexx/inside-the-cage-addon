{
  "namespace": "cursors",

  "cursor_main": {
    "type": "custom",
    "size": [ 16, 16 ],
    "renderer": "cursor_renderer",
    "layer": 4,
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = '' or #cursor_string = 'cursorState_zz')",
        "target_property_name": "#visible"
      }
    ]
  },

  "gun_cursor_states": {
    "type": "panel",
    "size": [ 7, 7 ],
    "anchor_from": "center",
    "anchor_to": "center",
    "alpha": 0.5,
    "propagate_alpha": true,
    "controls": [
      { "math_core@cursors.math_core": {} },

      { "cursor_normal@cursors.cursor_normal": {} },
      { "cursor_green@cursors.cursor_green": {} },
      { "cursor_blue@cursors.cursor_blue": {} },
      { "cursor_red@cursors.cursor_red": {} },

      { "shoot_panel@cursors.shoot_panel": {} }
    ]
  },

  "math_core": {
    "type": "panel",
    "size": [ 0, 0 ],
    "property_bag": {
      "#cursor_string": "cursorState_zz"
    },
    "bindings": [
      {
        "binding_name": "#hud_subtitle_text_string"
      },
      {
        "binding_type": "view",
        "source_property_name": "(%.14s * #hud_subtitle_text_string)",
        "target_property_name": "#cursor_string"
      }
    ]
  },

  "cursor_normal": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/gun_cursors/cursor_normal",
    "bindings": [
      {
        "binding_type": "view",
        "resolve_sibling_scope": true,
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = 'cursorState_00' or #cursor_string = 'cursorState_x0')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_green": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/gun_cursors/cursor_green",
    "bindings": [
      {
        "binding_type": "view",
        "resolve_sibling_scope": true,
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = 'cursorState_01' or #cursor_string = 'cursorState_x1')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_blue": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/gun_cursors/cursor_blue",
    "bindings": [
      {
        "binding_type": "view",
        "resolve_sibling_scope": true,
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = 'cursorState_02' or #cursor_string = 'cursorState_x2')",
        "target_property_name": "#visible"
      }
    ]
  },

  "cursor_red": {
    "type": "image",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/gun_cursors/cursor_red",
    "bindings": [
      {
        "binding_type": "view",
        "resolve_sibling_scope": true,
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = 'cursorState_03')",
        "target_property_name": "#visible"
      }
    ]
  },


  "shoot_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_type": "view",
        "binding_condition": "always",
        "resolve_sibling_scope": true,
        "source_control_name": "math_core",
        "source_property_name": "(#cursor_string = 'cursorState_03' or #cursor_string = 'cursorState_x3')",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "factory": {
          "type": "collection_panel",
          "factory": {
            "name": "hitmarker",
            "control_name": "cursors.hitmarker"
          },
          "bindings": [
            {
              "binding_type": "view",
              "binding_condition": "always",
              "source_control_name": "math_core",
              "source_property_name": "((#cursor_string = 'cursorState_x3') * 1)",
              "target_property_name": "#collection_length"
            }
          ]
        }
      }
    ]
  },

  "hitmarker": {
    "type": "image",
    "size": [44, 44],
    "anchor_from": "center",
    "anchor_to": "center",
    "texture": "textures/ui/gun_cursors/hitmarker",
    "uv": [ 0, 0 ],
    "uv_size": [ 256, 256 ],
    "anims": [ "@cursors.hitmarker_flipbook_anim" ]
  },

  "hitmarker_flipbook_anim": {
    "anim_type": "flip_book",
    "frame_count": 12,
    "frame_step": 256,
    "fps": 60,
    "reversible": false,
    "next": "@cursors.hitmarker_fade_out_anim"
  },

  "hitmarker_fade_out_anim": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": 0.2,
    "from": 1.0,
    "to": 0.0
  }
}