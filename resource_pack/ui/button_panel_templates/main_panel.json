{
  "namespace": "main_panel",

  "main_panel_container": {
    "type": "panel",
    "size": ["100%", "100%"],
    "offset": [0, 10],
    "controls": [
      {
        "main_stack_panel": {
            "type": "stack_panel",
            "orientation": "horizontal",
            "size": ["100%", "100%"],
            "collection_name": "form_buttons",
            "controls": [
              {
                "first_button@main_panel.button_panel": {
                  "$image_size": [64, 64],
                  "$padding_size": [138, 156],
                  "$must_show_hover_text": false,
                  "collection_index": 0
                }
              },
              {
                "top_right_stack_panel": {
                  "type": "stack_panel",
                  "orientation": "vertical",
                  "size": ["100%", "100%"],
                  "collection_name": "form_buttons",
                  "controls": [
                    {
                      "second_button@main_panel.button_panel": {
                        "$padding_size": [148, 52],
                        "$must_show_hover_text": false,
                        "collection_index": 1
                      }
                    },
                    {
                      "third_button@main_panel.button_panel": {
                        "$padding_size": [148, 52],
                        "$icon_size": [96, 48],
                        "$must_show_hover_text": true,
                        "collection_index": 2
                      }
                    },
                    {
                      "fourth_button@main_panel.button_panel": {
                        "$padding_size": [148, 52],
                        "$icon_size": [96, 48],
                        "$must_show_hover_text": true,
                        "collection_index": 3
                      }
                    }
                  ]
                }
              }
            ]
        }
      }
    ]
  },
  "button_panel": {
    "type": "panel",
    "size": "$padding_size",
 
    "$padding_size|default": [74, 74],
    "$button_size|default": ["100% - 10px", "100% - 10px"],
    "$icon_size|default": ["50%", "100x%"],

    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",

    "$light_border_hover_color": "textures/ui/focus_border_white",
    "controls": [
      {
        "button_ui": {
          "type": "panel",
          "size": "$button_size",
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 64,
                "size": "$icon_size",
                "bindings":[
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "text": {
                "type": "label",
                "text": "#form_button_text",
                "layer": 96,
                "color": [1.0, 1.0, 1.0],
                "offset": [0, -2],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "image",
                    "source_property_name": "(not (#texture = ''))",
                    "target_property_name": "#visible",
                    "resolve_sibling_scope": true
                  }
                ]
              }
            },
            {
              "button": {
                "type": "button",
                "size": [ "100%", "100%" ],
                "sound_name": "random.click",
                "layer": 10,
                
                "default_control": "default_state",
                "hover_control": "hover_state",
                "pressed_control": "pressed_state",

                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ],

                "controls": [
                  {
                    "default_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "default_image": {
                            "type": "image",
                            "texture": "$default_button_texture",
                            "layer": 32
                          }
                        }
                      ]
                    }
                  },
                  {
                    "hover_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "hover_image": {
                            "type": "image",
                            "texture": "$hover_button_texture",
                            "layer": 32
                          }
                        },
                        {
                          "hover_border_image": {
                            "type": "image",
                            "texture": "$light_border_hover_color",
                            "layer": 32
                          }
                        },
                        {
                          "hover_text_renderer@main_panel.hover_text_renderer": {
                            "$must_show_hover_text_final": "$must_show_hover_text"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "pressed_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "pressed_image": {
                            "type": "image",
                            "texture": "$pressed_button_texture",
                            "layer": 32
                          }
                        },
                        {
                          "pressed_border_image": {
                            "type": "image",
                            "texture": "$light_border_hover_color",
                            "layer": 32
                          }
                        },
                        {
                          "hover_text_renderer@main_panel.hover_text_renderer": {
                            "$must_show_hover_text_final": "$must_show_hover_text"
                          }
                        }
                      ]
                    }
                  }
                ],
                "button_mappings": [
                  {
                    "mapping_type": "pressed",
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.form_button_click",
                    "button_up_right_of_first_refusal": true
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },


  "content_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "form_body@main_panel.form_body": {} },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "main_panel_container@main_panel.main_panel_container": {} }
    ]
  },

  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "texture": "textures/ui/panels/main_panel/background",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "layer": 5,
    "controls": [
      { 
        "background_image@main_panel.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "form_text@main_panel.form_text": {} }
    ]
  },

  "form_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  },

  "close_button": {
    "type": "button",
    "size": [14, 14],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "default_control": "default_state",
    "hover_control": "hover_state",
    "pressed_control": "pressed_state",
    "sound_name": "random.click",
    "$default_texture": "textures/ui/panels/main_panel/close_button",
    "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
    "$alpha": 1,
    "$size": [16, 16],
    "button_mappings": [
      {
        "mapping_type": "pressed",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_exit"
      },
      {
        "mapping_type": "focused",
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_exit"
      }
    ],
    "controls": [
      {
        "background_image@main_panel.background_image": {
            "alpha": 1
        }
      },
      {
        "default_state": {
            "type": "image",
            "size": "$size",
            "texture": "$default_texture",
            "alpha": "$alpha"
        }
      },
      {
        "hover_state": {
            "type": "image",
            "size": "$size",
            "texture": "$hover_texture",
            "alpha": "$alpha"
        }
      },
      {
        "pressed_state": {
            "type": "image",
            "size": "$size",
            "texture": "$hover_texture",
            "alpha": "$alpha"
        }
      }
    ]
  },

  "hover_text_renderer": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "layer": 128,
    "allow_clipping": false,

    "$hover_text|default": "Price: §e7 §fCoins\n------------\nClick to buy",
    "$must_show_hover_text_final|default": false,

    "property_bag": {
      "#text_value": "$hover_text",
      "#render_hover_text": "$must_show_hover_text_final"
    },
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "#text_value",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "#render_hover_text",
        "target_property_name": "#visible"
      }
    ]
  }
}