{
  "namespace": "main_panel",

  "main_panel_container": {
    "type": "panel",
    "size": ["100%", "100%"],
    "offset": [0, 10],
    "controls": [
      {
        "main_stack_panel": {
            "type": "stack_panel",
            "orientation": "horizontal",
            "size": ["100%", "100%"],
            "collection_name": "form_buttons",
            "controls": [
              {
                "main_shop_button@button_elements_template.button_panel": {
                  "collection_index": 0,
                  "$image_size": [64, 64],
                  "$padding_size": [138, 156],
                  "$must_show_hover_text": false,

                  "$default_focus_precedence": 5,
                  "$focus_identifier": "main_shop_button_focus_id",
                  "$focus_change_up": "main_panel_close_button_focus_id",
                  "$focus_change_right": "main_vote_button_focus_id"
                }
              },
              {
                "top_right_stack_panel": {
                  "type": "stack_panel",
                  "orientation": "vertical",
                  "size": ["100%", "100%"],
                  "collection_name": "form_buttons",
                  "controls": [
                    {
                      "main_vote_button@button_elements_template.button_panel": {
                        "collection_index": 1,
                        "$padding_size": [148, 52],
                        "$must_show_hover_text": false,

                        "$default_focus_precedence": 4,
                        "$focus_identifier": "main_vote_button_focus_id",
                        "$focus_change_up": "main_panel_close_button_focus_id",
                        "$focus_change_left": "main_shop_button_focus_id",
                        "$focus_change_down": "main_battery_button_focus_id"
                      }
                    },
                    {
                      "main_battery_button@button_elements_template.button_panel": {
                        "collection_index": 2,
                        "$padding_size": [148, 52],
                        "$icon_size": [96, 48],
                        "$must_show_hover_text": true,

                        "$default_focus_precedence": 3,
                        "$focus_identifier": "main_battery_button_focus_id",
                        "$focus_change_left": "main_shop_button_focus_id",
                        "$focus_change_down": "main_stamina_button_focus_id",
                        "$focus_change_up": "main_vote_button_focus_id"
                      }
                    },
                    {
                      "main_stamina_button@button_elements_template.button_panel": {
                        "collection_index": 3,

                        "$padding_size": [148, 52],
                        "$icon_size": [96, 48],
                        "$must_show_hover_text": true,

                        "$default_focus_precedence": 2,
                        "$focus_identifier": "main_stamina_button_focus_id",
                        "$focus_change_left": "main_shop_button_focus_id",
                        "$focus_change_up": "main_battery_button_focus_id"
                      }
                    }
                  ]
                }
              }
            ]
        }
      }
    ]
  },
  

  "hover_text_renderer": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "layer": 128,
    "allow_clipping": false,

    "$hover_text|default": "Price: §e7 §fCoins\n------------\nClick to buy",
    "$must_show_hover_text_final|default": false,

    "property_bag": {
      "#text_value": "$hover_text",
      "#render_hover_text": "$must_show_hover_text_final"
    },
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "#text_value",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "#render_hover_text",
        "target_property_name": "#visible"
      }
    ]
  }
}