{
  "namespace": "button_elements_template",

  // ===== BUTTON PANELS =====

  // --- ACTION FORM PANELS ---

  "button_panel": {
    "type": "panel",
    "size": "$padding_size",

    "focus_container": true,

    "$button_panel_control_path|default": "button_elements_template.buttons_template",
    "$button_panel_control_name|default": "buttons_template",
 
    "$padding_size|default": [74, 74],
    "$button_size|default": ["100% - 10px", "100% - 10px"],
    "$icon_size|default": ["50%", "100x%"],

    "controls": [
      {
        "button_ui": {
          "type": "panel",
          "size": "$button_size",
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 64,
                "size": "$icon_size",
                "bindings": [
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "$button_panel_control_name@$button_panel_control_path": {}
            }
          ]
        }
      }
    ]
  },

  "button_panel_small": {
    "type": "panel",
    "size": "$padding_size",

    "$padding_size|default": [248, 52],
    "$button_size|default": ["100% - 10px", "100% - 10px"],

    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",
    "$button_light_borders": "textures/ui/focus_border_white",

    "$focus_wrap_enabled|default": false,
    
    "controls": [
      {
        "container": {
          "type": "panel",
          "size": ["100% - 10px", "100% - 10px"],
          "controls": [
            {
              "small_button@buttons_template": {
                "size": "$button_size",
                "focus_wrap_enabled": "$focus_wrap_enabled", // This does not work for panels
                "$button_text_anchors": "center"
              }
            }
          ]
        }
      }
    ]
  },


  // --- MODAL FORM PANELS ---

  "text_field_panel": {
    "type": "stack_panel",
    "size": ["100%", "100%c"],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",

    "controls": [
      {
        "label": {
          "type": "label",
          "text": "#custom_text",
          "bindings": [
            {
              "binding_type": "collection",
              "binding_collection_name": "custom_form",
              "binding_name": "#custom_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not (#custom_text = ''))",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "space_1": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "input": {
          "type": "edit_box",
          "size": ["100%", 30],

          "focus_enabled": true,

          "default_control": "default",
          "hover_control": "hover",
          "pressed_control": "pressed",

          "max_length": 4,
          "text_box_name": "custom_input",
          "text_control": "display_text",
          "place_holder_control": "place_holder",
          "text_edit_box_grid_collection_name": "custom_form",

          "controls": [
            { "default@common.edit_box_indent": {} },
            { "hover@common.edit_box_indent_hover": {} },
            { "pressed@common.edit_box_indent_hover": {} },
            {
              "display_text": {
                "type": "label",
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "offset": [ 4, 0 ],
                "layer": 2,

                "text": "#item_name",
                "color": [ 1.0, 1.0, 1.0 ],
                "text_alignment": "left",
                
                "bindings": [
                  {
                    "binding_type": "none",
                    "binding_collection_name": "",
                    "binding_collection_prefix": ""
                  },
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "custom_form",
                    "binding_name": "#custom_input_text",
                    "binding_name_override": "#item_name",
                    "binding_condition": "visible"
                  },
                  {
                    "binding_type": "none",
                    "binding_name": "#edit_box_text_color",
                    "binding_name_override": "#color"
                  },
                  {
                    "binding_name": "#newline_refresh"
                  }
                ]
              }
            },
            {
              "place_holder": {
                "type": "label",
                "text": "#custom_placeholder_text",
                "color": [0.6, 0.6, 0.6], 
                "offset": [4, 0],
                "layer": 2,
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "bindings": [
                  {
                    "binding_type": "view",
                    "resolve_sibling_scope": true,
                    "source_control_name": "display_text",
                    "source_property_name": "(#item_name = '')",
                    "target_property_name": "#visible"
                  },
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "custom_form",
                    "binding_name": "#custom_placeholder_text",
                    "binding_condition": "visible"
                  }
                ]
              }
            }
          ],
          "bindings": [
            {
              "binding_type": "none",
              "binding_collection_name": "",
              "binding_collection_prefix": ""
            },
            {
              "binding_type": "global",
              "binding_collection_name": "custom_form",
              "binding_name": "#custom_input_enabled",
              "binding_name_override": "#enabled"
            },
            {
              "binding_type": "none",
              "binding_name": "#can_be_deselected",
              "binding_name_override": "#can_be_deselected"
            },
            {
              "binding_type": "none",
              "binding_name": "#text_edit_box_focusable",
              "binding_name_override": "#focus_enabled"
            },
            {
              "binding_type": "none",
              "binding_collection_name": "",
              "binding_name": "#text_edit_box_visible",
              "binding_name_override": "#visible"
            },
            {
              "binding_type": "collection_details",
              "binding_collection_name": "factory_collection",
              "binding_collection_prefix": "factory"
            },
            {
              "binding_type": "collection",
              "binding_collection_name": "custom_form",
              "binding_name": "#custom_input_text"
            },
            {
              "binding_type": "collection",
              "binding_collection_name": "custom_form",
              "binding_name": "#custom_text"
            }
          ],
          "button_mappings": [
            {
              "from_button_id": "button.menu_select",
              "to_button_id": "button.text_edit_box_selected",
              "handle_select": true,
              "handle_deselect": false,
              "mapping_type": "pressed"
            },
            {
              "from_button_id": "button.menu_select",
              "to_button_id": "button.text_edit_box_deselected",
              "handle_select": false,
              "handle_deselect": true,
              "consume_event": false,
              "mapping_type": "global"
            },
            {
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.text_edit_box_selected",
              "handle_select": true,
              "handle_deselect": true,
              "mapping_type": "pressed"
            },
            {
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.text_edit_box_selected",
              "handle_select": false,
              "handle_deselect": true,
              "mapping_type": "global"
            },
            {
              "from_button_id": "button.menu_cancel",
              "to_button_id": "button.text_edit_box_deselected",
              "handle_select": false,
              "handle_deselect": true,
              "mapping_type": "global"
            },
            {
              "to_button_id": "button.text_edit_box_hovered",
              "mapping_type": "pressed"
            },
            {
              "from_button_id": "button.menu_clear",
              "to_button_id": "button.text_edit_box_clear",
              "handle_select": false,
              "handle_deselect": false,
              "mapping_type": "focused"
            }
          ]
        }
      },
      {
        "space_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      }
    ]
  },

  // ===== BUTTONS =====

  "buttons_template": {
    "type": "button",
    "anchor_from": "center",
    "anchor_to": "center",
    "size": [ "100%", "100%" ],
    "sound_name": "random.click",

    "$offset|default": [ 0, 0 ],
    "$button_text_anchors|default": "bottom_middle",

    "$show_hover_text_renderer|default": false,

    "$default_text|default": "#form_button_text",
    "$hover_text|default": "#form_button_text",

    "$focus_identifier|default": "",
    "$default_focus_precedence|default": 0,

    "$default_button_texture|default": "textures/ui/panels/main_panel/background",
    "$hover_button_texture|default": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture|default": "textures/ui/panels/main_panel/background_pressed",
    "$button_light_borders|default": "textures/ui/focus_border_white",
    
    "focus_enabled": true,
    "focus_identifier": "$focus_identifier",
    "default_focus_precedence": "$default_focus_precedence",

    "default_control": "default_state",
    "hover_control": "hover_state",
    "pressed_control": "pressed_state",

    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name": "#form_button_text"
      }
    ],
    "controls": [
      {
        "default_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "default_image": {
                "type": "image",
                "texture": "$default_button_texture"
              }
            },
            {
              "default_text": {
                "type": "label",
                "text": "$default_text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "hover_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "hover_image": {
                "type": "image",
                "texture": "$hover_button_texture"
              }
            },
            {
              "hover_border_image": {
                "type": "image",
                "texture": "$button_light_borders",
                "layer": 32
              }
            },
            {
              "hover_text": {
                "type": "label",
                "text": "$hover_text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            },
            { "hover_text_renderer@button_elements_template.hover_text_renderer": {} }
          ]
        }
      },
      {
        "pressed_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "pressed_image": {
                "type": "image",
                "texture": "$pressed_button_texture"
              }
            },
            {
              "pressed_border_image": {
                "type": "image",
                "texture": "$button_light_borders",
                "layer": 32
              }
            },
            {
              "pressed_text": {
                "type": "label",
                "text": "$hover_text",
                "anchor_from": "$button_text_anchors",
                "anchor_to": "$button_text_anchors",
                "offset": "$offset",
                "layer": 32,
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            },
            { "hover_text_renderer@button_elements_template.hover_text_renderer": {} }
          ]
        }
      }
    ],
    "button_mappings": [
      {
        "mapping_type": "pressed",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.form_button_click",
        "button_up_right_of_first_refusal": true
      },
      {
        "mapping_type": "focused",
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.form_button_click"
      }
    ]
  },

  // --- ACTION FORM BUTTONS ---

  "main_panel_buttons@button_elements_template.buttons_template": {
    "$focus_change_up|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_down|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_right|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_left|default": "FOCUS_OVERRIDE_STOP",

    "focus_change_up": "$focus_change_up",
    "focus_change_down": "$focus_change_down",
    "focus_change_right": "$focus_change_right",
    "focus_change_left": "$focus_change_left"
  },

  "shop_panel_buttons@button_elements_template.buttons_template": {
    "$offset": [ 0, -2 ]
  },

  // --- MODAL FORM BUTTONS ---

  "submit_button@button_elements_template.buttons_template": {
    "size": ["100%", 32],
    "offset": [ 0, 10 ],

    "$default_text": "#submit_text",
    "$hover_text": "#submit_text",
    "$button_text_anchors": "center",

    "bindings": [
      {
        "binding_name": "#submit_button_visible",
        "binding_name_override": "#visible"
      },
      {
        "binding_name": "#submit_text",
        "binding_condition": "once"
      }
    ],
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.submit_custom_form",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.submit_custom_form",
        "mapping_type": "focused"
      }
    ]
  },

  // --- CLOSE BUTTONS ---

  "close_button_container": {
    "type": "panel",
    "offset": [8, -8],
    "layer": 64,

    "$focus_identifier|default": "",
    "focus_container": true,
    "focus_navigation_mode_right": "stop",
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_up": "stop",
    "controls": [
      {
        "close_button": {
          "type": "button",
          "size": [14, 14],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "sound_name": "random.click",

          "default_control": "default_state",
          "hover_control": "hover_state",
          "pressed_control": "pressed_state",

          "focus_enabled": true,
          "default_focus_precedence": 1,
          "focus_identifier": "$focus_identifier",

          "$default_texture": "textures/ui/panels/main_panel/close_button",
          "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
          
          "$alpha": 1,
          "$size": [16, 16],
          "button_mappings": [
            {
              "mapping_type": "pressed",
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit"
            },
            {
              "mapping_type": "focused",
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.menu_exit"
            }
          ],
          "controls": [
            {
              "background_image@button_elements_template.background_image": {
                  "alpha": 1
              }
            },
            {
              "default_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$default_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "hover_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "pressed_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            }
          ]
        }
      }
    ]
  },

  "close_button_container_detailed@close_button_container": {
    "$other_focus_container_name|default": "",
    "focus_navigation_mode_down": "custom",
    "focus_container_custom_down": [
      {
        "other_focus_container_name": "$other_focus_container_name"
      }
    ]
  },

  // OTHERS

  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "texture": "textures/ui/panels/main_panel/background",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "content_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "$container_name|default": "button_panel",
    "$container_reference|default": "button_elements_template.button_panel",
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "form_body@button_elements_template.form_body": {} },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "$container_name@$container_reference": {} }
    ]
  },



  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "$text_name|default": "long_text",
    "$text_name_reference|default": "button_elements_template.long_text",
    "layer": 5,
    "controls": [
      { 
        "background_image@button_elements_template.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "$text_name@$text_name_reference": {} }
    ]
  },

  "long_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  },

  "custom_text": {
    "type": "label",
    "text": "#custom_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#custom_text"
      }
    ]
  },


  "hover_text_renderer": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "layer": 128,
    "allow_clipping": false,

    "$custom_hover_text|default": "",
    "$show_hover_text_renderer|default": false,

    "property_bag": {
      "#text_value": "$custom_hover_text",
      "#render_hover_text": "$show_hover_text_renderer"
    },
    "bindings": [
      {
        "binding_type": "view",
        "source_property_name": "#text_value",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "#render_hover_text",
        "target_property_name": "#visible"
      }
    ]
  }
}