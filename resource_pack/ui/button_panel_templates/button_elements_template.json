{
  "namespace": "button_elements_template",

  "close_button_container": {
    "type": "panel",
    "offset": [8, -8],
    "layer": 64,

    "$focus_identifier|default": "",
    "$focus_container_custom_down|default": "",
    "focus_container": true,
    "focus_navigation_mode_right": "stop",
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_up": "stop",
    "controls": [
      {
        "close_button": {
          "type": "button",
          "size": [14, 14],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "sound_name": "random.click",

          "default_control": "default_state",
          "hover_control": "hover_state",
          "pressed_control": "pressed_state",

          "focus_enabled": true,
          "focus_identifier": "$focus_identifier",

          "$default_texture": "textures/ui/panels/main_panel/close_button",
          "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
          
          "$alpha": 1,
          "$size": [16, 16],
          "button_mappings": [
            {
              "mapping_type": "pressed",
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit"
            },
            {
              "mapping_type": "focused",
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.menu_exit"
            }
          ],
          "controls": [
            {
              "background_image@button_elements_template.background_image": {
                  "alpha": 1
              }
            },
            {
              "default_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$default_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "hover_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "pressed_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            }
          ]
        }
      }
    ]
  },

  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "texture": "textures/ui/panels/main_panel/background",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "content_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "$container_name|efault": "main_panel_container",
    "$container_reference|default": "button_elements_template.main_panel_container",
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "form_body@button_elements_template.form_body": {} },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "$container_name@$container_reference": {} }
    ]
  },



  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "layer": 5,
    "controls": [
      { 
        "background_image@button_elements_template.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "form_text@button_elements_template.form_text": {} }
    ]
  },

  "form_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  }
}