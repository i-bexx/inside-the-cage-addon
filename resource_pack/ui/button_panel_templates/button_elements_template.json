{
  "namespace": "button_elements_template",

  // BUTTON PANELS

  "button_panel": {
    "type": "panel",
    "size": "$padding_size",

    "focus_container": true,

    "$button_panel_control_path|default": "button_elements_template.main_panel_buttons",
    "$button_panel_control_name|default": "main_panel_buttons",
 
    "$padding_size|default": [74, 74],
    "$button_size|default": ["100% - 10px", "100% - 10px"],
    "$icon_size|default": ["50%", "100x%"],
    "$show_outer_text|default": true,

    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",

    "$light_border_hover_color": "textures/ui/focus_border_white",
    "controls": [
      {
        "button_ui": {
          "type": "panel",
          "size": "$button_size",
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 64,
                "size": "$icon_size",
                "bindings":[
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "text": {
                "type": "label",
                "ignored": "(not $show_outer_text)",
                "text": "#form_button_text",
                "layer": 96,
                "color": [1.0, 1.0, 1.0],
                "offset": [0, -2],
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "image",
                    "source_property_name": "(not (#texture = ''))",
                    "target_property_name": "#visible",
                    "resolve_sibling_scope": true
                  }
                ]
              }
            },
            {
              "$button_panel_control_name@$button_panel_control_path": {}
            }
          ]
        }
      }
    ]
  },

  "button_panel_small": {
    "type": "panel",
    "size": "$padding_size",

    "$padding_size|default": [248, 52],
    "$button_size|default": ["100% - 10px", "100% - 10px"],

    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",
    "controls": [
      {
        "container": {
          "type": "panel",
          "size": ["100% - 10px", "100% - 10px"],
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 200,
                "size": ["50%", "50%"],
                "offset": [0, -5]
              }
            },
            {
              "form_button": {
                "type": "button",
                "size": "$button_size",
                "sound_name": "random.click",

                "focus_enabled": true,
                "focus_wrap_enabled": false, // This does not work for panels
                
                "default_control": "default_state",
                "hover_control": "hover_state",
                "pressed_control": "pressed_state",

                "controls": [
                  {
                    "default_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "default_image": {
                            "type": "image",
                            "texture": "$default_button_texture"
                          }
                        },
                        {
                          "default_text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "anchor_from": "center",
                            "anchor_to": "center",
			                      "layer": 200,
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "hover_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "hover_image": {
                            "type": "image",
                            "texture": "$hover_button_texture"
                          }
                        },
                        {
                          "hover_text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "anchor_from": "center",
                            "anchor_to": "center",
			                      "layer": 200,
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "pressed_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "pressed_image": {
                            "type": "image",
                            "texture": "$pressed_button_texture"
                          }
                        },
                        {
                          "pressed_text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "anchor_from": "center",
                            "anchor_to": "center",
			                      "layer": 200,
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ],
                "button_mappings": [
                  {
                    "mapping_type": "pressed",
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.form_button_click",
                    "button_up_right_of_first_refusal": true
                  },
                  {
                    "mapping_type": "focused",
                    "from_button_id": "button.menu_ok",
                    "to_button_id": "button.form_button_click"
                  }
                ],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  // PANEL BUTTONS

  "main_panel_buttons": {
    "type": "button",
    "size": [ "100%", "100%" ],
    "sound_name": "random.click",
    "layer": 10,

    "$focus_identifier|default": "",
    "$default_focus_precedence|default": 0,
    "$focus_change_up|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_down|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_right|default": "FOCUS_OVERRIDE_STOP",
    "$focus_change_left|default": "FOCUS_OVERRIDE_STOP",

    "focus_enabled": true,
    "default_focus_precedence": "$default_focus_precedence",
    "focus_identifier": "$focus_identifier",
    "focus_change_up": "$focus_change_up",
    "focus_change_down": "$focus_change_down",
    "focus_change_right": "$focus_change_right",
    "focus_change_left": "$focus_change_left",
    
    "default_control": "default_state",
    "hover_control": "hover_state",
    "pressed_control": "pressed_state",

    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ],

    "controls": [
      {
        "default_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "default_image": {
                "type": "image",
                "texture": "$default_button_texture",
                "layer": 32
              }
            }
          ]
        }
      },
      {
        "hover_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "hover_image": {
                "type": "image",
                "texture": "$hover_button_texture",
                "layer": 32
              }
            },
            {
              "hover_border_image": {
                "type": "image",
                "texture": "$light_border_hover_color",
                "layer": 32
              }
            },
            {
              "hover_text_renderer@main_panel.hover_text_renderer": {
                "$must_show_hover_text_final": "$must_show_hover_text"
              }
            }
          ]
        }
      },
      {
        "pressed_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "pressed_image": {
                "type": "image",
                "texture": "$pressed_button_texture",
                "layer": 32
              }
            },
            {
              "pressed_border_image": {
                "type": "image",
                "texture": "$light_border_hover_color",
                "layer": 32
              }
            },
            {
              "hover_text_renderer@main_panel.hover_text_renderer": {
                "$must_show_hover_text_final": "$must_show_hover_text"
              }
            }
          ]
        }
      }
    ],
    "button_mappings": [
      {
        "mapping_type": "pressed",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.form_button_click",
        "button_up_right_of_first_refusal": true
      },
      {
        "mapping_type": "focused",
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.form_button_click"
      }
    ]
  },

  "shop_panel_buttons": {
    "type": "button",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "size": [ "100%", "100%" ],
    "sound_name": "random.click",

    "$focus_identifier|default": "",
    "$default_focus_precedence|default": 0,
    
    "focus_enabled": true,
    "focus_identifier": "$focus_identifier",
    "default_focus_precedence": "$default_focus_precedence",

    "default_control": "default_state",
    "hover_control": "hover_state",
    "pressed_control": "pressed_state",
    "controls": [
      {
        "default_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "default_image": {
                "type": "image",
                "texture": "$default_button_texture"
              }
            },
            {
              "default_text": {
                "type": "label",
                "text": "#form_button_text",
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [0, -2],
                "layer": 200,
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "hover_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "hover_image": {
                "type": "image",
                "texture": "$hover_button_texture"
              }
            },
            {
              "hover_text": {
                "type": "label",
                "text": "$hover_text",
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [0, -2],
                "layer": 200
              }
            }
          ]
        }
      },
      {
        "pressed_state": {
          "type": "panel",
          "size": [ "100%", "100%" ],
          "controls": [
            {
              "pressed_image": {
                "type": "image",
                "texture": "$pressed_button_texture"
              }
            },
            {
              "pressed_text": {
                "type": "label",
                "text": "$hover_text",
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "offset": [0, -2],
                "layer": 200
              }
            }
          ]
        }
      }
    ],
    "button_mappings": [
      {
        "mapping_type": "pressed",
        "from_button_id": "button.menu_select",
        "to_button_id": "button.form_button_click",
        "button_up_right_of_first_refusal": true
      },
      {
        "mapping_type": "focused",
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.form_button_click"
      }
    ],
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  // CLOSE BUTTONS

  "close_button_container": {
    "type": "panel",
    "offset": [8, -8],
    "layer": 64,

    "$focus_identifier|default": "",
    "focus_container": true,
    "focus_navigation_mode_right": "stop",
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_up": "stop",
    "controls": [
      {
        "close_button": {
          "type": "button",
          "size": [14, 14],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "sound_name": "random.click",

          "default_control": "default_state",
          "hover_control": "hover_state",
          "pressed_control": "pressed_state",

          "focus_enabled": true,
          "default_focus_precedence": 1,
          "focus_identifier": "$focus_identifier",

          "$default_texture": "textures/ui/panels/main_panel/close_button",
          "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
          
          "$alpha": 1,
          "$size": [16, 16],
          "button_mappings": [
            {
              "mapping_type": "pressed",
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit"
            },
            {
              "mapping_type": "focused",
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.menu_exit"
            }
          ],
          "controls": [
            {
              "background_image@button_elements_template.background_image": {
                  "alpha": 1
              }
            },
            {
              "default_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$default_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "hover_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "pressed_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            }
          ]
        }
      }
    ]
  },

  "close_button_container_detailed": {
    "type": "panel",
    "offset": [8, -8],
    "layer": 64,
    "$focus_identifier|default": "",
    "$button_down_name|default": "",

    "focus_container": true,
    "default_focus_precedence": 1,
    "focus_navigation_mode_right": "stop",
    "focus_navigation_mode_left": "stop",
    "focus_navigation_mode_up": "stop",
    "focus_navigation_mode_down": "custom",
    "focus_container_custom_down": [
      {
        "other_focus_container_name": "$other_focus_container_name"
      }
    ],
    "controls": [
      {
        "close_button": {
          "type": "button",
          "size": [14, 14],
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "sound_name": "random.click",

          "default_control": "default_state",
          "hover_control": "hover_state",
          "pressed_control": "pressed_state",

          "focus_enabled": true,
          "focus_identifier": "$focus_identifier",

          "$default_texture": "textures/ui/panels/main_panel/close_button",
          "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
          
          "$alpha": 1,
          "$size": [16, 16],
          "button_mappings": [
            {
              "mapping_type": "pressed",
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit"
            },
            {
              "mapping_type": "focused",
              "from_button_id": "button.menu_ok",
              "to_button_id": "button.menu_exit"
            }
          ],
          "controls": [
            {
              "background_image@button_elements_template.background_image": {
                  "alpha": 1
              }
            },
            {
              "default_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$default_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "hover_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            },
            {
              "pressed_state": {
                  "type": "image",
                  "size": "$size",
                  "texture": "$hover_texture",
                  "alpha": "$alpha"
              }
            }
          ]
        }
      }
    ]
  },

  // OTHERS

  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "texture": "textures/ui/panels/main_panel/background",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "content_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "$container_name|efault": "main_panel_container",
    "$container_reference|default": "button_elements_template.main_panel_container",
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "form_body@button_elements_template.form_body": {} },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "$container_name@$container_reference": {} }
    ]
  },



  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "layer": 5,
    "controls": [
      { 
        "background_image@button_elements_template.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "form_text@button_elements_template.form_text": {} }
    ]
  },

  "form_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  }
}