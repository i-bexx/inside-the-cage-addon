{
  "namespace": "shop_panel",

  "shop_panel_container": {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "scrolling_panel@common.scrolling_panel": {
          "anchor_from": "center",
          "anchor_to": "center",
          "size": [ "100%", "100%" ],
          "$show_background": false,
          "$scrolling_content": "shop_panel.button_creator",
          "$scroll_size": [ 5, "100% - 4px" ],
          "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
          "$scrolling_pane_offset": [ 2, 0 ],
          "$scroll_bar_right_padding_size": [ 0, 0 ]
        }
      }
    ]
  },
  
  "button_creator": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"], 
    
    "$show_outer_text": false,
    "$button_panel_control_path": "button_elements_template.shop_panel_buttons",
    "$button_panel_control_name": "shop_panel_buttons",
    "controls": [
      {
        "row_1_wrapper": {
          "type": "panel",
          "size": ["100%", 74], 
          "controls": [
            {
              "shop_button_container_1": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74], 
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "none",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "gun_button@button_elements_template.button_panel": {
                      "collection_index": 0,

                      "$hover_text": "§l§e4 Coins",
                      "$focus_identifier": "gun_button_focus_id",
                      "$default_focus_precedence": 10
                    }
                  },
                  {
                    "knife_button@button_elements_template.button_panel": {
                      "collection_index": 1,

                      "$hover_text": "§l§e2 Coins",
                      "$focus_identifier": "knife_button_focus_id",
                      "$default_focus_precedence": 9
                    }
                  },
                  {
                    "kit_button@button_elements_template.button_panel": {
                      "collection_index": 2,

                      "$hover_text": "§l§e7 Coins",
                      "$focus_identifier": "kit_button_focus_id",
                      "$default_focus_precedence": 8
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_1": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_2_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_3"
                  }
                ],
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_1"
                  }
                ],
                "controls": [
                  {
                    "toxic_bomb_button@button_elements_template.button_panel": {
                      "collection_index": 3,

                      "$hover_text": "§l§e6 Coins",
                      "$focus_identifier": "toxic_bomb_button_focus_id",
                      "$default_focus_precedence": 7
                    }
                  },
                  {
                    "ammo_button@button_elements_template.button_panel": {
                      "collection_index": 4,

                      "$hover_text": "§l§e1 Coin",
                      "$focus_identifier": "ammo_button_focus_id",
                      "$default_focus_precedence": 6
                    }
                  },
                  {
                    "battery_button@button_elements_template.button_panel": {
                      "collection_index": 5,
                      
                      "$hover_text": "§l§e3 Coins",
                      "$focus_identifier": "battery_button_focus_id",
                      "$default_focus_precedence": 5
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_2": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_3_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_3": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                
                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "stop",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "btn_6@button_elements_template.button_panel": {
                      "collection_index": 6,

                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null1_button_focus_id",
                      "$default_focus_precedence": 4
                    }
                  },
                  {
                    "btn_7@button_elements_template.button_panel": {
                      "collection_index": 7,

                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null2_button_focus_id",
                      "$default_focus_precedence": 3
                    }
                  },
                  {
                    "btn_8@button_elements_template.button_panel": {
                      "collection_index": 8,
                      
                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null3_button_focus_id",
                      "$default_focus_precedence": 2
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}