{
  "namespace": "shop_panel",

  "shop_panel_container" : {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "scrolling_panel@common.scrolling_panel": {
          "anchor_from": "center",
          "anchor_to": "center",
          "$show_background": false,
          "size": [ "100%", "100%" ],
          "$scrolling_content": "shop_panel.button_creator",
          "$scroll_size": [ 5, "100% - 4px" ],
          "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
          "$scrolling_pane_offset": [ 2, 0 ],
          "$scroll_bar_right_padding_size": [ 0, 0 ]
        }
      }
    ]
  },
  "button_creator": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"], 
    "controls": [
      {
        "row_1_wrapper": {
          "type": "panel",
          "size": ["100%", 74], 
          "controls": [
            {
              "creator_1": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74], 
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                "controls": [
                  { "gun_button@shop_panel.button_panel": { "collection_index": 0, "$hover_text": "§l§e4 Coins" } },
                  { "knife_button@shop_panel.button_panel": { "collection_index": 1, "$hover_text": "§l§e2 Coins" } },
                  { "kit_button@shop_panel.button_panel": { "collection_index": 2, "$hover_text": "§l§e7 Coins" } }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_1": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_2_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "creator_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                "controls": [
                  { "toxic_bomb_button@shop_panel.button_panel": { "collection_index": 3, "$hover_text": "§l§e6 Coins" } },
                  { "ammo_button@shop_panel.button_panel": { "collection_index": 4, "$hover_text": "§l§e1 Coins" } },
                  { "battery_button@shop_panel.button_panel": { "collection_index": 5, "$hover_text": "§l§e3 Coins" } }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_2": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_3_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "creator_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                "controls": [
                  { "btn_6@shop_panel.button_panel": { "collection_index": 6, "$hover_text": "§l§e... Coins" } },
                  { "btn_7@shop_panel.button_panel": { "collection_index": 7, "$hover_text": "§l§e... Coins" } },
                  { "btn_8@shop_panel.button_panel": { "collection_index": 8, "$hover_text": "§l§e... Coins" } }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "button_panel": {
    "type": "panel",
    "size": [68, 68],

    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",
    "controls": [
      {
        "container": {
          "type": "panel",
          "size": ["100% - 10px", "100% - 10px"],
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 200,
                "size": ["50%", "50%"],
                "offset": [0, -5],
                "bindings":[
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "form_button": {
                "type": "button",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "size": [ "100%", "100%" ],
                "sound_name": "random.click",
                
                "default_control": "default_state",
                "hover_control": "hover_state",
                "pressed_control": "pressed_state",

                "controls": [
                  {
                    "default_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "default_image": {
                            "type": "image",
                            "texture": "$default_button_texture"
                          }
                        },
                        {
                          "default_text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
			                      "layer": 200,
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "hover_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "hover_image": {
                            "type": "image",
                            "texture": "$hover_button_texture"
                          }
                        },
                        {
                          "hover_text": {
                            "type": "label",
                            "text": "$hover_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
			                      "layer": 200
                          }
                        }
                      ]
                    }
                  },
                  {
                    "pressed_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "hover_image": {
                            "type": "image",
                            "texture": "$pressed_button_texture"
                          }
                        },
                        {
                          "hover_text": {
                            "type": "label",
                            "text": "$hover_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
			                      "layer": 200
                          }
                        }
                      ]
                    }
                  }
                ],
                "button_mappings": [
                  {
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.form_button_click",
                    "button_up_right_of_first_refusal": true
                  },
                  {
                    "from_button_id": "button.menu_ok",
                    "to_button_id": "button.form_button_click",
                    "mapping_type": "focused"
                  }
                ],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },



  "content_stack": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "size": ["100%", "100%"],
    "controls": [
      {
        "padding": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "form_body@shop_panel.form_body": {} },
      {
        "padding_2": {
          "type": "panel",
          "size": ["100%", 8]
        }
      },
      { "shop_panel_container@shop_panel.shop_panel_container": {} }
    ]
  },

  "background_image": {
    "type": "image",
    "size": ["100% + 5px", "100% + 5px"],
    "texture": "textures/ui/panels/main_panel/background",
    "alpha": 0.8
  },

  "label_text": {
    "type": "label",
    "text": "#title_text",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [9, -16],
    "font_type": "MinecraftTen",
    "font_size": "large",
    "layer": 5,
    "bindings": [
      {
        "binding_name": "#title_text"
      }
    ]
  },

  "form_body": {
    "type": "panel",
    "size": ["100%", 16],
    "layer": 5,
    "controls": [
      { 
        "background_image@shop_panel.background_image": {
          "size": ["100% - 32px", "100%"]
        } 
      },
      { "form_text@shop_panel.form_text": {} }
    ]
  },

  "form_text": {
    "type": "label",
    "text": "#form_text",
    "font_size": "normal",
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_text"
      }
    ]
  },

  "close_button": {
    "type": "button",
    "size": [14, 14],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "default_control": "default_state",
    "hover_control": "hover_state",
    "sound_name": "random.click",
    "$default_texture": "textures/ui/panels/main_panel/close_button",
    "$hover_texture": "textures/ui/panels/main_panel/close_button_hover",
    "$alpha": 1,
    "$size": [16, 16],
    "button_mappings": [
      {
        "from_button_id": "button.menu_select",
        "to_button_id": "button.menu_exit",
        "mapping_type": "pressed"
      },
      {
        "from_button_id": "button.menu_ok",
        "to_button_id": "button.menu_exit",
        "mapping_type": "focused"
      }
    ],
    "controls": [
      {
        "background_image@shop_panel.background_image": {
            "alpha": 1
        }
      },
      {
        "default_state": {
            "type": "image",
            "size": "$size",
            "texture": "$default_texture",
            "alpha": "$alpha"
        }
      },
      {
        "hover_state": {
            "type": "image",
            "size": "$size",
            "texture": "$hover_texture",
            "alpha": "$alpha"
        }
      }
    ]
  }
}