{
  "namespace": "shop_panel",

  "shop_panel_container": {
    "type": "panel",
    "size": ["100%", "fill"],
    "layer": 1,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "scrolling_panel@common.scrolling_panel": {
          "anchor_from": "center",
          "anchor_to": "center",
          "$show_background": false,
          "size": [ "100%", "100%" ],
          "$scrolling_content": "shop_panel.button_creator",
          "$scroll_size": [ 5, "100% - 4px" ],
          "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
          "$scrolling_pane_offset": [ 2, 0 ],
          "$scroll_bar_right_padding_size": [ 0, 0 ]
        }
      }
    ]
  },
  
  "button_creator": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"], 
    "controls": [
      {
        "row_1_wrapper": {
          "type": "panel",
          "size": ["100%", 74], 
          "controls": [
            {
              "shop_button_container_1": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74], 
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "none",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "gun_button@shop_panel.button_panel": {
                      "collection_index": 0,
                      "$hover_text": "§l§e4 Coins",
                      "$focus_identifier": "gun_button_focus_id"
                    }
                  },
                  {
                    "knife_button@shop_panel.button_panel": {
                      "collection_index": 1,
                      "$hover_text": "§l§e2 Coins",
                      "$focus_identifier": "knife_button_focus_id"
                    }
                  },
                  {
                    "kit_button@shop_panel.button_panel": {
                      "collection_index": 2,
                      "$hover_text": "§l§e7 Coins",
                      "$focus_identifier": "kit_button_focus_id"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_1": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_2_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_2": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",

                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "custom",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_down": [
                  {
                    "other_focus_container_name": "shop_button_container_3"
                  }
                ],
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_1"
                  }
                ],
                "controls": [
                  {
                    "toxic_bomb_button@shop_panel.button_panel": {
                      "collection_index": 3,
                      "$hover_text": "§l§e6 Coins",
                      "$focus_identifier": "toxic_bomb_button_focus_id"
                    }
                  },
                  {
                    "ammo_button@shop_panel.button_panel": {
                      "collection_index": 4,
                      "$hover_text": "§l§e1 Coin",
                      "$focus_identifier": "ammo_button_focus_id"
                    }
                  },
                  {
                    "battery_button@shop_panel.button_panel": {
                      "collection_index": 5,
                      "$hover_text": "§l§e3 Coins",
                      "$focus_identifier": "battery_button_focus_id"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "gap_2": {
          "type": "panel",
          "size": ["100%", 4]
        }
      },
      {
        "row_3_wrapper": {
          "type": "panel",
          "size": ["100%", 74],
          "controls": [
            {
              "shop_button_container_3": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": ["100%c", 74],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "collection_name": "form_buttons",
                
                "focus_container": true,
                "focus_navigation_mode_right": "stop",
                "focus_navigation_mode_left": "stop",
                "focus_navigation_mode_down": "stop",
                "focus_navigation_mode_up": "custom",
                "focus_container_custom_up": [
                  {
                    "other_focus_container_name": "shop_button_container_2"
                  }
                ],
                "controls": [
                  {
                    "btn_6@shop_panel.button_panel": {
                      "collection_index": 6,
                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null1_button_focus_id"
                    }
                  },
                  {
                    "btn_7@shop_panel.button_panel": {
                      "collection_index": 7,
                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null2_button_focus_id"
                    }
                  },
                  {
                    "btn_8@shop_panel.button_panel": {
                      "collection_index": 8,
                      "$hover_text": "§l§e... Coins",
                      "$focus_identifier": "null3_button_focus_id"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "button_panel": {
    "type": "panel",
    "size": [68, 68],
    "$default_button_texture": "textures/ui/panels/main_panel/background",
    "$hover_button_texture": "textures/ui/panels/main_panel/background_hover",
    "$pressed_button_texture": "textures/ui/panels/main_panel/background_pressed",
    "controls": [
      {
        "container": {
          "type": "panel",
          "size": ["100% - 10px", "100% - 10px"],
          "controls": [
            {
              "image": {
                "type": "image",
                "layer": 200,
                "size": ["50%", "50%"],
                "offset": [0, -5],
                "bindings":[
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "form_button": {
                "type": "button",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "size": [ "100%", "100%" ],
                "sound_name": "random.click",
                "$focus_identifier|default": "",
                "focus_enabled": true,
                "focus_identifier": "$focus_identifier",
                "default_control": "default_state",
                "hover_control": "hover_state",
                "pressed_control": "pressed_state",
                "controls": [
                  {
                    "default_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "default_image": {
                            "type": "image",
                            "texture": "$default_button_texture"
                          }
                        },
                        {
                          "default_text": {
                            "type": "label",
                            "text": "#form_button_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
                            "layer": 200,
                            "bindings": [
                              {
                                "binding_name": "#form_button_text",
                                "binding_type": "collection",
                                "binding_collection_name": "form_buttons"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "hover_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "hover_image": {
                            "type": "image",
                            "texture": "$hover_button_texture"
                          }
                        },
                        {
                          "hover_text": {
                            "type": "label",
                            "text": "$hover_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
                            "layer": 200
                          }
                        }
                      ]
                    }
                  },
                  {
                    "pressed_state": {
                      "type": "panel",
                      "size": [ "100%", "100%" ],
                      "controls": [
                        {
                          "pressed_image": {
                            "type": "image",
                            "texture": "$pressed_button_texture"
                          }
                        },
                        {
                          "pressed_text": {
                            "type": "label",
                            "text": "$hover_text",
                            "anchor_from": "bottom_middle",
                            "anchor_to": "bottom_middle",
                            "offset": [0, -2],
                            "layer": 200
                          }
                        }
                      ]
                    }
                  }
                ],
                "button_mappings": [
                  {
                    "mapping_type": "pressed",
                    "from_button_id": "button.menu_select",
                    "to_button_id": "button.form_button_click",
                    "button_up_right_of_first_refusal": true
                  },
                  {
                    "mapping_type": "focused",
                    "from_button_id": "button.menu_ok",
                    "to_button_id": "button.form_button_click"
                  }
                ],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}